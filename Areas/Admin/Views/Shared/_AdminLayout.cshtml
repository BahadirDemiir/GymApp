<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Admin Panel</title>
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <!-- Admin Layout CSS -->
    <link rel="stylesheet" href="~/css/admin-layout.css" />
    
    <!-- Custom Admin CSS -->
    <link rel="stylesheet" href="~/css/admin.css" />
    
    <!-- Custom Styles Section -->
    @RenderSection("Styles", required: false)
</head>
<body>
    <!-- Sidebar Toggle Button -->
    <button class="sidebar-toggle" id="sidebarToggle" title="Toggle Sidebar">
        <i class="bi bi-list"></i>
    </button>

    <!-- Admin Sidebar -->
    <aside class="admin-sidebar" id="adminSidebar">
        <div class="admin-sidebar-header">
            <a href="/Admin/Dashboard" class="admin-sidebar-brand">
                <i class="bi bi-shield-lock"></i>
                <span class="brand-text">Admin Panel</span>
            </a>
        </div>
        
        <nav class="admin-sidebar-nav">
            <ul>
                <li>
                    <a href="/home/Index" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Index" && ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
                        <i class="bi bi-speedometer2"></i>
                        <span class="nav-text">Anasayfa</span>
                    </a>
                </li>
                <li>
                    <a href="/Admin/Gym/addGym" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "addGym" ? "active" : "")">
                        <i class="bi bi-building"></i>
                        <span class="nav-text">Spor Salonu Ekle</span>
                    </a>
                </li>
                <li>
                    <a href="/Admin/Gym/AddGymStaff" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "AddGymStaff" ? "active" : "")">
                        <i class="bi bi-person-plus"></i>
                        <span class="nav-text">Personel Ekle</span>
                    </a>
                </li>
                <li>
                    <a href="/Admin/Coach/addCoach" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "addCoach" ? "active" : "")">
                        <i class="bi bi-person-badge"></i>
                        <span class="nav-text">Koç Ekle</span>
                    </a>
                </li>
                <li>
                    <a href="/Admin/Course/addCourse" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "addCourse" ? "active" : "")">
                        <i class="bi bi-calendar-event"></i>
                        <span class="nav-text">Kurs Ekle</span>
                    </a>
                </li>
                <li>
                    <a href="/Admin/Staff/List" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "List" ? "active" : "")">
                    <i class="bi bi-calendar-event"></i>
                    <span class="nav-tes">Staff Listesi</span>
                    </a>
                </li>
            </ul>
        </nav>
    </aside>

    <!-- Main Content -->
    <main class="admin-content" id="adminContent">
        <div class="admin-header">
            <h1>@ViewData["Title"]</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="/Admin/Dashboard">Admin</a></li>
                    <li class="breadcrumb-item active" aria-current="page">@ViewData["Title"]</li>
                </ol>
            </nav>
        </div>
        
        @RenderBody()
    </main>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    
    <!-- Admin Layout JS -->
    <script src="~/js/admin-layout.js"></script>
    
    <!-- Custom Scripts Section -->
    @RenderSection("Scripts", required: false)
</body>
</html>
@using GymAppFresh.Models.ViewModel
@model GymCreateVm

@section Styles {
    <link rel="stylesheet" href="~/css/addLayout.css" asp-append-version="true" />
    <!-- Leaflet CSS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <style>
        .interactive-map {
            height: 400px;
            width: 100%;
            border-radius: 8px;
            border: 2px solid #e2e8f0;
            overflow: hidden;
        }
        
        .map-container {
            background: #f8fafc;
            padding: 1rem;
            border-radius: 8px;
            border: 1px solid #e2e8f0;
        }
        
        .map-header {
            border-bottom: 1px solid #e2e8f0;
            padding-bottom: 0.5rem;
        }
        
        .map-info {
            background: white;
            padding: 0.75rem;
            border-radius: 6px;
            border: 1px solid #e2e8f0;
        }
        
        #currentCoords {
            font-weight: 600;
            color: #0ea5e9;
        }
        
        /* Marker styles matching map.cshtml */
        .sbx-pin .pin {
            width: 16px;
            height: 16px;
            border-radius: 50%;
            background: #00754a;
            box-shadow: 0 0 0 4px rgba(0, 117, 74, 0.18), 0 4px 10px rgba(0, 0, 0, 0.15);
            border: 2px solid #fff;
        }
        
        /* Image Upload Styles */
        .image-upload-container {
            position: relative;
        }
        
        .upload-area {
            position: relative;
            border: 2px dashed #e2e8f0;
            border-radius: 12px;
            padding: 2rem;
            text-align: center;
            background: #f8fafc;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        
        .upload-area:hover {
            border-color: #0ea5e9;
            background: #f0f9ff;
        }
        
        .upload-area.dragover {
            border-color: #0ea5e9;
            background: #e0f2fe;
            transform: scale(1.02);
        }
        
        .upload-content {
            pointer-events: none;
        }
        
        .file-input {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            opacity: 0;
            cursor: pointer;
        }
        
        .image-preview-container {
            background: white;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            padding: 1rem;
        }
        
        .image-preview-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
            gap: 1rem;
            margin-bottom: 1rem;
        }
        
        .image-preview-item {
            position: relative;
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        }
        
        .image-preview-item img {
            width: 100%;
            height: 120px;
            object-fit: cover;
            display: block;
        }
        
        .image-preview-item .remove-btn {
            position: absolute;
            top: 5px;
            right: 5px;
            background: rgba(239, 68, 68, 0.9);
            color: white;
            border: none;
            border-radius: 50%;
            width: 24px;
            height: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 12px;
            transition: all 0.2s ease;
        }
        
        .image-preview-item .remove-btn:hover {
            background: rgba(239, 68, 68, 1);
            transform: scale(1.1);
        }
        
        .image-preview-item .file-info {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            background: rgba(0, 0, 0, 0.7);
            color: white;
            padding: 4px 8px;
            font-size: 11px;
            text-align: center;
        }

    </style>
}

<!-- Header Section -->
<section class="form-header py-4">
    <div class="container">
        <div class="row justify-content-center text-center">
            <div class="col-lg-8">
                <h1 class="display-6 fw-bold text-dark mb-2">Yeni Spor Salonu Ekle</h1>
                <p class="lead text-muted mb-0">Sisteme yeni bir spor salonu konumu ekleyin</p>
            </div>
        </div>
    </div>
</section>

<!-- Form Section -->
<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10 col-xl-8">
                <div class="form-container p-4 p-lg-5">
                    
                    <!-- Validation Summary -->
                    @if (!ViewData.ModelState.IsValid && ViewContext.HttpContext.Request.Method == "POST")
                    {
                        <div class="alert alert-danger" role="alert">
                            <h6 class="alert-heading">
                                <i class="bi bi-exclamation-triangle me-2"></i>Lütfen aşağıdaki hataları düzeltin:
                            </h6>
                            <div asp-validation-summary="All" class="mb-0"></div>
                        </div>
                    }

                    <form asp-action="addGym" asp-controller="Gym" method="post" id="addGymForm" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()

                        <!-- Basic Information Section -->
                        <div class="form-section">
                            <h5>
                                <i class="bi bi-building"></i>
                                Temel Bilgiler
                            </h5>
                        
                            <div class="form-floating mb-3">
                                <input type="text" asp-for="Name" class="form-control" 
                                       placeholder="Spor salonu adı" id="gymName" required />
                                <label for="gymName">Spor Salonu Adı *</label>
                                <span asp-validation-for="Name" class="text-danger validation-message"></span>
                                <div class="form-text">Spor salonunun tam adını girin</div>
                            </div>

                            <!-- City Dropdown -->
                            <div class="form-floating mb-3">
                                <select asp-for="CityId"
                                        asp-items="ViewBag.Cities"
                                        class="form-select"
                                        id="gymCity"
                                        required>
                                    <option value="">Şehir seçiniz</option>
                                </select>
                                <label for="gymCity">Şehir *</label>
                                <span asp-validation-for="CityId" class="text-danger validation-message"></span>
                                <div class="form-text">Salonun bağlı olduğu şehri seçiniz</div>
                            </div>
                        </div>

                        <!-- Location Coordinates Section -->
                        <div class="form-section">
                            <h5>
                                <i class="bi bi-geo-alt"></i>
                                Konum Koordinatları
                            </h5>
                            
                            <div class="coordinate-inputs">
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-floating mb-3">
                                            <input type="number" asp-for="Latitude" class="form-control" 
                                                   placeholder="Enlem" id="latitude" 
                                                   step="0.000001" min="-90" max="90" required />
                                            <label for="latitude">Enlem (Latitude) *</label>
                                            <span asp-validation-for="Latitude" class="text-danger validation-message"></span>
                                            <div class="form-text">Örnek: 41.0082</div>
                                        </div>
                                    </div>
                                    
                                    <div class="col-md-6">
                                        <div class="form-floating mb-3">
                                            <input type="number" asp-for="Longitude" class="form-control" 
                                                   placeholder="Boylam" id="longitude" 
                                                   step="0.000001" min="-180" max="180" required />
                                            <label for="longitude">Boylam (Longitude) *</label>
                                            <span asp-validation-for="Longitude" class="text-danger validation-message"></span>
                                            <div class="form-text">Örnek: 28.9784</div>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="row">
                                    <div class="col-12">
                                        <div class="d-flex gap-2">
                                            <button type="button" class="btn btn-outline-secondary btn-sm" id="openGoogleMaps">
                                                <i class="bi bi-map me-2"></i>Google Maps'te Aç
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Interactive Map Preview -->
                            <div class="map-container mb-3">
                                <div class="map-header d-flex justify-content-between align-items-center mb-2">
                                    <h6 class="mb-0">
                                        <i class="bi bi-map me-2"></i>Harita Önizlemesi
                                    </h6>
                                    <small class="text-muted">Haritada bir yere tıklayarak koordinatları otomatik olarak ayarlayabilirsiniz</small>
                                </div>
                                <div id="map" class="interactive-map"></div>
                                <div class="map-info mt-2">
                                    <div class="d-flex align-items-center justify-content-between">
                                        <span class="text-muted small">
                                            <i class="bi bi-info-circle me-1"></i>
                                            Koordinatlar: <span id="currentCoords">Henüz seçilmedi</span>
                                        </span>
                                        <button type="button" class="btn btn-sm btn-outline-primary" id="centerMap">
                                            <i class="bi bi-crosshair me-1"></i>Merkeze Al
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Working Hours -->
                        <div class="form-section">
                            <h5>
                                <i class="bi bi-clock"></i>
                                Çalışma Saatleri
                            </h5>

                            <div class="form-floating mb-3">
                                <input type="time" asp-for="OpenTime" class="form-control" 
                                       placeholder="OpenTime" id="OpenTime" 
                                       step="1" min="06:00" max="23:00" required />
                                <label for="OpenTime">Açılış Saati</label>
                                <span asp-validation-for="OpenTime" class="text-danger validation-message"></span>
                                <div class="form-text">Açılış saatini giriniz</div>
                            </div>

                            <div class="form-floating mb-3">
                                <input type="time" asp-for="CloseTime" class="form-control" 
                                       placeholder="CloseTime" id="CloseTime" 
                                       step="1" min="06:00" max="23:00" required />
                                <label for="CloseTime">Kapanış Saati</label>
                                <span asp-validation-for="CloseTime" class="text-danger validation-message"></span>
                                <div class="form-text">Kapanış saatini giriniz</div>
                            </div>

                            
                            <div class="form-floating mb-3">
                                <input type="time" asp-for="WOpenTime" class="form-control" id="WOpenTime" step="1" />
                                <label for="WOpenTime">Hafta Sonu Açılış</label>
                                <span asp-validation-for="WOpenTime" class="text-danger validation-message"></span>
                            </div>
                            <div class="form-floating mb-3">
                                <input type="time" asp-for="WCloseTime" class="form-control" id="WCloseTime" step="1" />
                                <label for="WCloseTime">Hafta Sonu Kapanış</label>
                                <span asp-validation-for="WCloseTime" class="text-danger validation-message"></span>
                            </div>
                        </div>

                        <!-- Image Upload -->
                        <div class="form-section">
                            <h5>
                                <i class="bi bi-image"></i>
                                Salon Görselleri
                            </h5>

                            <div class="image-upload-container mb-3">
                                <div class="upload-area" id="uploadArea">
                                    <div class="upload-content">
                                        <i class="bi bi-cloud-upload display-4 text-muted"></i>
                                        <h6 class="mt-2 mb-1">Resim Yüklemek İçin Tıklayın</h6>
                                        <p class="text-muted mb-0">veya sürükleyip bırakın</p>
                                        <small class="text-muted">PNG, JPG, JPEG (Maksimum 5MB)</small>
                                    </div>
                                    <input asp-for="Photos" type="file" class="file-input" 
                                           id="gymImage" multiple accept="image/*" />
                                </div>
                                
                                <!-- Seçilen Resimler Önizlemesi -->
                                <div class="image-preview-container mt-3" id="imagePreviewContainer" style="display: none;">
                                    <h6 class="mb-2">
                                        <i class="bi bi-images me-2"></i>Seçilen Resimler
                                    </h6>
                                    <div class="image-preview-grid" id="imagePreviewGrid">
                                        <!-- JavaScript ile doldurulacak -->
                                    </div>
                                    <div class="text-muted small mt-2">
                                        <i class="bi bi-info-circle me-1"></i>
                                        Toplam: <span id="selectedImageCount">0</span> resim
                                    </div>
                                </div>
                                
                                <span asp-validation-for="Photos" class="text-danger validation-message"></span>
                            </div>
                        </div>

                        <!-- Current Member -->
                        <div class="form-section">
                            <h5>
                                <i class="bi bi-people"></i>
                                Salon Üye Sayısı
                            </h5>

                            <div class="form-floating mb-3">
                                <input type="number" asp-for="CurrentMember" class="form-control" 
                                       placeholder="CurrentMember" id="CurrentMember" required min="0" />
                                <label for="CurrentMember">Üye Sayısı</label>
                                <span asp-validation-for="CurrentMember" class="text-danger validation-message"></span>
                            </div>
                        </div>

                        <!-- Status Section -->
                        <div class="form-section">
                            <h5>
                                <i class="bi bi-toggle-on"></i>
                                Durum
                            </h5>
                            
                            <div class="status-toggle">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" asp-for="IsActive" id="isActive" />
                                    <label class="form-check-label" for="isActive">
                                        Spor Salonu Aktif
                                    </label>
                                </div>
                                <div class="form-text">
                                    Aktif olan spor salonları kullanıcılara gösterilir
                                </div>
                            </div>
                        </div>

                        <!-- Form Actions -->
                        <div class="d-flex gap-3 justify-content-end pt-4">
                            <a asp-controller="Gym" asp-action="gymList" class="btn btn-cancel text-white">
                                <i class="bi bi-x-circle me-2"></i>İptal
                            </a>
                            <button type="submit" class="btn btn-submit text-white">
                                <i class="bi bi-check-circle me-2"></i>Spor Salonu Ekle
                            </button>
                        </div>
                    </form> 
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script src="~/js/gym-add.js"></script>
    <!-- Leaflet JavaScript -->
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="~/js/turkey-map.js"></script>
}

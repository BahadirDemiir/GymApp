@model GymAppFresh.Models.Coach

@section Styles {
    <link rel="stylesheet" href="~/css/addLayout.css" asp-append-version="true" />
}

<!-- Header Section -->
<section class="form-header py-4">
    <div class="container">
        <div class="row justify-content-center text-center">
            <div class="col-lg-8">
                <h1 class="display-6 fw-bold text-dark mb-2">Yeni Koç Ekle</h1>
                <p class="lead text-muted mb-0">Spor salonuna yeni bir koç ekleyin</p>
            </div>
        </div>
    </div>
</section>

<!-- Form Section -->
<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10 col-xl-8">
                <div class="form-container p-4 p-lg-5">
                    
                    <!-- Validation Summary -->
                    @if (!ViewData.ModelState.IsValid && ViewContext.HttpContext.Request.Method == "POST")
                    {
                        <div class="alert alert-danger" role="alert">
                            <h6 class="alert-heading">
                                <i class="bi bi-exclamation-triangle me-2"></i>Lütfen aşağıdaki hataları düzeltin:
                            </h6>
                            <div asp-validation-summary="All" class="mb-0"></div>
                        </div>
                    }

                    <form asp-action="AddCoach" asp-controller="Coach" method="post" enctype="multipart/form-data" id="addCoachForm">
                        
                        <!-- Basic Information Section -->
                        <div class="form-section">
                            <h5>
                                <i class="bi bi-person-circle"></i>
                                Temel Bilgiler
                            </h5>
                            
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-floating">
                                        <input type="text" asp-for="Name" class="form-control" 
                                               placeholder="Koç adı" id="coachName" />
                                        <label for="coachName">Koç Adı *</label>
                                        <span asp-validation-for="Name" class="text-danger validation-message"></span>
                                    </div>
                                </div>
                                
                                <div class="col-md-6">
                                    <div class="form-floating">
                                        <select asp-for="CategoryId"
                                            asp-items="ViewBag.Categories"
                                            class="form-select"
                                            id="coachCategory" required>
                                        <option value="">Seçiniz</option>
                                    </select>
                                    <label for="coachCategory">Kategori *</label>
                                    <span asp-validation-for="CategoryId" class="text-danger validation-message"></span>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-floating">
                                        <input type="number" asp-for="ExperienceYears" class="form-control" 
                                               placeholder="Deneyim yılı" id="experienceYears" min="0" max="50" />
                                        <label for="experienceYears">Deneyim Yılı</label>
                                        <span asp-validation-for="ExperienceYears" class="text-danger validation-message"></span>
                                    </div>
                                </div>
                                
                                <div class="col-md-6">
                                    <div class="form-floating">
                                        <select asp-for="Level" class="form-select" id="coachLevel">
                                            <option value="">Seçiniz</option>
                                            <option value="Başlangıç">Başlangıç</option>
                                            <option value="Orta">Orta</option>
                                            <option value="İleri">İleri</option>
                                            <option value="Uzman">Uzman</option>
                                        </select>
                                        <label for="coachLevel">Seviye</label>
                                        <span asp-validation-for="Level" class="text-danger validation-message"></span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Media & Links Section -->
                        <div class="form-section">
                            <h5>
                                <i class="bi bi-image"></i>
                                Medya ve Bağlantılar
                            </h5>
                            
                            
                            
                            <div class="form-floating">
                                <input type="url" asp-for="InstagramUrl" class="form-control" 
                                       placeholder="Instagram URL'si" id="instagramUrl" />
                                <label for="instagramUrl">Instagram Profil URL'si *</label>
                                <span asp-validation-for="InstagramUrl" class="text-danger validation-message"></span>


                            </div>

                            <div class="form-floating">
                                <input type="file" name="photo" class="form-control" 
                                       placeholder="Instagram URL'si" id="coachImage" />
                                <label for="instagramUrl">Resim*</label>
                                <span name="photo" class="text-danger validation-message"></span>
                            </div>

                            

                            
                        </div>

                        <!-- Biography Section -->
                        <div class="form-section">
                            <h5>
                                <i class="bi bi-file-text"></i>
                                Biyografi
                            </h5>
                            
                            <div class="form-floating">
                                <textarea asp-for="Bio" class="form-control" 
                                          placeholder="Koç hakkında bilgi" id="coachBio" 
                                          style="height: 120px"></textarea>
                                <label for="coachBio">Biyografi *</label>
                                <span asp-validation-for="Bio" class="text-danger validation-message"></span>
                                <div class="form-text">Koçunuz hakkında detaylı bilgi verin (maksimum 1000 karakter)</div>
                            </div>
                        </div>

                        <!-- Ratings & Stats Section -->
                        <div class="form-section">
                            <h5>
                                <i class="bi bi-star"></i>
                                Değerlendirme ve İstatistikler
                            </h5>
                            
                            <div class="row">
                                <div class="col-md-4">
                                    <div class="form-floating">
                                        <input type="number" asp-for="Rating" class="form-control" 
                                               placeholder="Puan" id="coachRating" 
                                               min="0" max="5" step="0.1" />
                                        <label for="coachRating">Başlangıç Puanı</label>
                                        <span asp-validation-for="Rating" class="text-danger validation-message"></span>
                                    </div>
                                </div>
                                
                                <div class="col-md-4">
                                    <div class="form-floating">
                                        <input type="number" asp-for="ReviewCount" class="form-control" 
                                               placeholder="Değerlendirme sayısı" id="reviewCount" min="0" />
                                        <label for="reviewCount">Değerlendirme Sayısı</label>
                                        <span asp-validation-for="ReviewCount" class="text-danger validation-message"></span>
                                    </div>
                                </div>
                                
                                <div class="col-md-4">
                                    <div class="form-floating">
                                        <input type="number" asp-for="StudentCount" class="form-control" 
                                               placeholder="Öğrenci sayısı" id="studentCount" min="0" />
                                        <label for="studentCount">Öğrenci Sayısı</label>
                                        <span asp-validation-for="StudentCount" class="text-danger validation-message"></span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Form Actions -->
                        <div class="d-flex gap-3 justify-content-end pt-4">
                            <a asp-controller="Coach" asp-action="Coachs" class="btn btn-cancel text-white">
                                <i class="bi bi-x-circle me-2"></i>İptal
                            </a>
                            <button type="submit" class="btn btn-submit text-white">
                                <i class="bi bi-check-circle me-2"></i>Koç Ekle
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const imageInput = document.getElementById('coachImage');
            const imagePreview = document.getElementById('imagePreview');
            
            // Image preview functionality
            imageInput.addEventListener('input', function() {
                const imageUrl = this.value.trim();
                
                if (imageUrl) {
                    // Create new image element
                    const img = document.createElement('img');
                    img.src = imageUrl;
                    img.onload = function() {
                        imagePreview.innerHTML = '';
                        imagePreview.appendChild(img);
                        imagePreview.classList.add('has-image');
                    };
                    img.onerror = function() {
                        imagePreview.innerHTML = `
                            <div class="text-danger">
                                <i class="bi bi-exclamation-triangle fs-1"></i>
                                <p class="mb-0">Resim yüklenemedi</p>
                            </div>
                        `;
                        imagePreview.classList.remove('has-image');
                    };
                } else {
                    imagePreview.innerHTML = `
                        <div class="text-muted">
                            <i class="bi bi-image fs-1"></i>
                            <p class="mb-0">Resim önizlemesi</p>
                        </div>
                    `;
                    imagePreview.classList.remove('has-image');
                }
            });
            
            // Form validation enhancement
            const form = document.getElementById('addCoachForm');
            form.addEventListener('submit', function(e) {
                const requiredFields = form.querySelectorAll('[required]');
                let isValid = true;
                
                requiredFields.forEach(field => {
                    if (!field.value.trim()) {
                        field.classList.add('is-invalid');
                        isValid = false;
                    } else {
                        field.classList.remove('is-invalid');
                        field.classList.add('is-valid');
                    }
                });
                
                if (!isValid) {
                    e.preventDefault();
                    // Scroll to first error
                    const firstError = form.querySelector('.is-invalid');
                    if (firstError) {
                        firstError.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    }
                }
            });
        });
    </script>
}
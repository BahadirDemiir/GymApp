@model GymAppFresh.Models.Course

@section Styles {
    <link rel="stylesheet" href="~/css/addLayout.css" asp-append-version="true" />
}

<!-- Header Section -->
<section class="form-header py-4">
    <div class="container">
        <div class="row justify-content-center text-center">
            <div class="col-lg-8">
                <h1 class="display-6 fw-bold text-dark mb-2">Yeni Kurs Ekle</h1>
                <p class="lead text-muted mb-0">Spor salonuna yeni bir kurs ekleyin</p>
            </div>
        </div>
    </div>
</section>

<!-- Form Section -->
<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10 col-xl-8">
                <div class="form-container p-4 p-lg-5">
                    
                    <!-- Validation Summary -->
                    @if (!ViewData.ModelState.IsValid && ViewContext.HttpContext.Request.Method == "POST")
                    {
                        <div class="alert alert-danger" role="alert">
                            <h6 class="alert-heading">
                                <i class="bi bi-exclamation-triangle me-2"></i>Lütfen aşağıdaki hataları düzeltin:
                            </h6>
                            <div asp-validation-summary="All" class="mb-0"></div>
                        </div>
                    }

                    <form asp-action="AddCourse" asp-controller="Course" method="post" enctype="multipart/form-data" id="addCourseForm">
                        
                        <!-- Basic Information Section -->
                        <div class="form-section">
                            <h5>
                                <i class="bi bi-book"></i>
                                Temel Bilgiler
                            </h5>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-floating">
                                        <input type="text" asp-for="Name" class="form-control" 
                                               placeholder="Kurs adı" id="courseName" />
                                        <label for="courseName">Kurs Adı *</label>
                                        <span asp-validation-for="Name" class="text-danger validation-message"></span>
                                    </div>
                                </div>
                                
                                <div class="col-md-6">
                                    <div class="form-floating">
                                        <select asp-for="CategoryId"
                                            asp-items="ViewBag.Categories"
                                            class="form-select"
                                            id="courseCategory">
                                        <option value="">Seçiniz</option>
                                    </select>
                                    <label for="courseCategory">Kategori *</label>
                                    <span asp-validation-for="CategoryId" class="text-danger validation-message"></span>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-floating">
                                        <select asp-for="CoachId"
                                            asp-items="ViewBag.Coaches"
                                            class="form-select"
                                            id="courseCoach">
                                        <option value="">Seçiniz (Opsiyonel)</option>
                                    </select>
                                    <label for="courseCoach">Koç</label>
                                    <span asp-validation-for="CoachId" class="text-danger validation-message"></span>
                                    </div>
                                </div>
                                
                                <div class="col-md-6">
                                    <div class="form-floating">
                                        <select asp-for="Level" class="form-select" id="courseLevel">
                                            <option value="">Seçiniz</option>
                                            <option value="Başlangıç">Başlangıç</option>
                                            <option value="Orta">Orta</option>
                                            <option value="İleri">İleri</option>
                                            <option value="Uzman">Uzman</option>
                                        </select>
                                        <label for="courseLevel">Seviye</label>
                                        <span asp-validation-for="Level" class="text-danger validation-message"></span>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-floating">
                                        <input type="date" asp-for="StartDate" class="form-control" 
                                               placeholder="Başlangıç tarihi" id="startDate" />
                                        <label for="startDate">Başlangıç Tarihi *</label>
                                        <span asp-validation-for="StartDate" class="text-danger validation-message"></span>
                                    </div>
                                </div>
                                
                                <div class="col-md-6">
                                    <div class="form-floating">
                                        <input type="number" asp-for="Duration" class="form-control" 
                                               placeholder="Süre" id="duration" min="0.5" max="10" step="0.5" />
                                        <label for="duration">Süre (Saat) *</label>
                                        <span asp-validation-for="Duration" class="text-danger validation-message"></span>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="form-floating">
                                <textarea asp-for="Description" class="form-control" 
                                          placeholder="Kurs açıklaması" id="courseDescription" 
                                          style="height: 120px"></textarea>
                                <label for="courseDescription">Kurs Açıklaması *</label>
                                <span asp-validation-for="Description" class="text-danger validation-message"></span>
                                <div class="form-text">Kursunuz hakkında detaylı bilgi verin (maksimum 1000 karakter)</div>
                            </div>
                        </div>

                        <!-- Course Image Section -->
                        <div class="form-section">
                            <h5>
                                <i class="bi bi-image"></i>
                                Kurs Görseli
                            </h5>   
                            <div class="form-floating">
                                <input type="file" name="photo" class="form-control" 
                                       placeholder="Resim ekleyiniz" id="courseImage" accept="image/*" />
                                <label for="courseImage">Resim *</label>
                                <span name="photo" class="text-danger validation-message"></span>
                            </div>
                        </div>
                        
                        <!-- Pricing & Capacity Section -->
                        <div class="form-section">
                            <h5>
                                <i class="bi bi-currency-dollar"></i>
                                Fiyatlandırma ve Kapasite
                            </h5>
                            
                            <div class="row">
                                <div class="col-md-4">
                                    <div class="form-floating">
                                        <input type="number" asp-for="Price" class="form-control" 
                                               placeholder="Fiyat" id="coursePrice" 
                                               min="0" step="0.01" />
                                        <label for="coursePrice">Fiyat (₺)</label>
                                        <span asp-validation-for="Price" class="text-danger validation-message"></span>
                                    </div>
                                </div>
                                
                                <div class="col-md-4">
                                    <div class="form-floating">
                                        <input type="number" asp-for="MaxStudents" class="form-control" 
                                               placeholder="Maksimum öğrenci" id="maxStudents" min="1" />
                                        <label for="maxStudents">Maksimum Öğrenci</label>
                                        <span asp-validation-for="MaxStudents" class="text-danger validation-message"></span>
                                    </div>
                                </div>
                                
                                <div class="col-md-4">
                                    <div class="form-floating">
                                        <input type="number" asp-for="CurrentStudents" class="form-control" 
                                               placeholder="Mevcut öğrenci" id="currentStudents" min="0" />
                                        <label for="currentStudents">Mevcut Öğrenci</label>
                                        <span asp-validation-for="CurrentStudents" class="text-danger validation-message"></span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Ratings & Reviews Section -->
                        <div class="form-section">
                            <h5>
                                <i class="bi bi-star"></i>
                                Değerlendirme ve Yorumlar
                            </h5>
                            
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-floating">
                                        <input type="number" asp-for="Rating" class="form-control" 
                                               placeholder="Puan" id="courseRating" 
                                               min="0" max="5" step="0.1" />
                                        <label for="courseRating">Başlangıç Puanı</label>
                                        <span asp-validation-for="Rating" class="text-danger validation-message"></span>
                                    </div>
                                </div>
                                
                                <div class="col-md-6">
                                    <div class="form-floating">
                                        <input type="number" asp-for="ReviewCount" class="form-control" 
                                               placeholder="Değerlendirme sayısı" id="reviewCount" min="0" />
                                        <label for="reviewCount">Değerlendirme Sayısı</label>
                                        <span asp-validation-for="ReviewCount" class="text-danger validation-message"></span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Form Actions -->
                        <div class="d-flex gap-3 justify-content-end pt-4">
                            <a asp-controller="Course" asp-action="Courses" class="btn btn-cancel text-white">
                                <i class="bi bi-x-circle me-2"></i>İptal
                            </a>
                            <button type="submit" class="btn btn-submit text-white">
                                <i class="bi bi-check-circle me-2"></i>Kurs Ekle
                            </button>
                        </div>
                    </form> 
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Form validation enhancement
            const form = document.getElementById('addCourseForm');
            form.addEventListener('submit', function(e) {
                const requiredFields = form.querySelectorAll('[required]');
                let isValid = true;
                
                requiredFields.forEach(field => {
                    if (!field.value.trim()) {
                        field.classList.add('is-invalid');
                        isValid = false;
                    } else {
                        field.classList.remove('is-invalid');
                        field.classList.add('is-valid');
                    }
                });
                
                if (!isValid) {
                    e.preventDefault();
                    // Scroll to first error
                    const firstError = form.querySelector('.is-invalid');
                    if (firstError) {
                        firstError.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    }
                }
            });
        });
    </script>
}
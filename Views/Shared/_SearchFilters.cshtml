@using Microsoft.AspNetCore.Routing

@{
    var searchPlaceholder = ViewData["SearchPlaceholder"] ?? "Ara...";
    var filterOptions = ViewData["FilterOptions"] as string[] ?? new[] { "Tümü" };
    var sortOptions = ViewData["SortOptions"] as Dictionary<string, string> ?? new();

    // mevcut query'den aktif filtreyi al
    var currentFilter = (Context.Request.Query["filter"].ToString() ?? "all");
}

<!-- Modern Search and Filters Section -->
<section class="search-filters-section py-5">
    <div class="container">
        <div class="search-filters-container">
            <div class="row g-4">
                <!-- Search Bar -->
                <div class="col-lg-5">
                    <div class="search-container">
                        <div class="search-input-wrapper">
                            <div class="search-icon">
                                <i class="bi bi-search"></i>
                            </div>
                            <input type="text" 
                                   class="search-input" 
                                   placeholder="@searchPlaceholder" 
                                   id="searchInput"
                                   autocomplete="off">
                            <div class="search-focus-border"></div>
                        </div>
                    </div>
                </div>
                
                <!-- Filter Chips -->
                <div class="col-lg-5">
                    <div class="filter-chips-container">
                        <div class="filter-chips-wrapper">
                            @foreach (var option in filterOptions)
                            {
                                var filterValue = option == "Tümü" ? "all" : option;
                                var isActive = string.Equals(filterValue, currentFilter, StringComparison.OrdinalIgnoreCase) ? "active" : "";

                                <button class="filter-chip @isActive" 
                                        data-filter="@filterValue"
                                        type="button">
                                    <span class="filter-chip-text">@option</span>
                                    <div class="filter-chip-ripple"></div>
                                </button>
                            }
                        </div>
                    </div>
                </div>
                
                <!-- Sort Dropdown -->
                <div class="col-lg-2">
                    <div class="sort-container">
                        <div class="sort-select-wrapper">
                            <select class="sort-select" id="sortSelect">
                                @foreach (var option in sortOptions)
                                {
                                    <option value="@option.Key">@option.Value</option>
                                }
                            </select>
                            <div class="sort-select-arrow">
                                <i class="bi bi-chevron-down"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
.search-filters-section {
    background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    border-bottom: 1px solid rgba(0,0,0,0.05);
}

.search-filters-container {
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(10px);
    border-radius: 20px;
    padding: 2rem;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
}

/* Search Input Styling */
.search-container {
    position: relative;
}

.search-input-wrapper {
    position: relative;
    background: white;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.search-input-wrapper:hover {
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.12);
    transform: translateY(-2px);
}

.search-input-wrapper:focus-within {
    box-shadow: 0 0 0 3px rgba(13, 110, 253, 0.1), 0 8px 30px rgba(0, 0, 0, 0.12);
}

.search-icon {
    position: absolute;
    left: 20px;
    top: 50%;
    transform: translateY(-50%);
    color: #6c757d;
    font-size: 1.1rem;
    z-index: 2;
    transition: color 0.3s ease;
}

.search-input-wrapper:focus-within .search-icon {
    color: #0d6efd;
}

.search-input {
    width: 100%;
    padding: 18px 20px 18px 60px;
    border: none;
    outline: none;
    font-size: 1rem;
    background: transparent;
    color: #495057;
    transition: all 0.3s ease;
}

.search-input::placeholder {
    color: #adb5bd;
    transition: color 0.3s ease;
}

.search-input:focus::placeholder {
    color: #6c757d;
}

.search-focus-border {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 3px;
    background: linear-gradient(90deg, #0d6efd, #0b5ed7);
    transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.search-input-wrapper:focus-within .search-focus-border {
    width: 100%;
}

/* Filter Chips Styling */
.filter-chips-container {
    display: flex;
    align-items: center;
}

.filter-chips-wrapper {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
}

.filter-chip {
    position: relative;
    background: white;
    border: none;
    border-radius: 50px;
    padding: 12px 24px;
    font-size: 0.9rem;
    font-weight: 500;
    color: #6c757d;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
    display: inline-block;
}

.filter-chip:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.12);
    color: #0d6efd;
}

.filter-chip.active {
    background: linear-gradient(135deg, #0d6efd, #0b5ed7);
    color: white;
    box-shadow: 0 6px 20px rgba(13, 110, 253, 0.3);
}

.filter-chip-text {
    position: relative;
    z-index: 2;
}

.filter-chip-ripple {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 0;
    height: 0;
    background: rgba(255, 255, 255, 0.3);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    transition: all 0.6s ease;
}

.filter-chip:active .filter-chip-ripple {
    width: 300px;
    height: 300px;
}

/* Sort Select Styling */
.sort-container {
    display: flex;
    align-items: center;
}

.sort-select-wrapper {
    position: relative;
    width: 100%;
    background: white;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.sort-select-wrapper:hover {
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.12);
    transform: translateY(-2px);
}

.sort-select {
    width: 100%;
    padding: 18px 50px 18px 20px;
    border: none;
    outline: none;
    font-size: 1rem;
    background: transparent;
    color: #495057;
    cursor: pointer;
    appearance: none;
    -webkit-appearance: none;
    -moz-appearance: none;
}

.sort-select-arrow {
    position: absolute;
    right: 20px;
    top: 50%;
    transform: translateY(-50%);
    color: #6c757d;
    pointer-events: none;
    transition: transform 0.3s ease;
}

.sort-select-wrapper:hover .sort-select-arrow {
    transform: translateY(-50%) rotate(180deg);
}


    
    .sort-container {
        justify-content: center;
        margin-top: 1rem;
    }
}


    
    .filter-chip {
        padding: 10px 20px;
        font-size: 0.85rem;
    }
    
    .sort-select {
        padding: 16px 50px 16px 20px;
        font-size: 0.9rem;
    }
}



.filter-chip {
    animation: chipPop 0.3s ease forwards;
}

.filter-chip:nth-child(1) { animation-delay: 0.1s; }
.filter-chip:nth-child(2) { animation-delay: 0.2s; }
.filter-chip:nth-child(3) { animation-delay: 0.3s; }
.filter-chip:nth-child(4) { animation-delay: 0.4s; }
.filter-chip:nth-child(5) { animation-delay: 0.5s; }
.filter-chip:nth-child(6) { animation-delay: 0.6s; }
.filter-chip:nth-child(7) { animation-delay: 0.7s; }
.filter-chip:nth-child(8) { animation-delay: 0.8s; }

/* Hover effects for better interactivity */
.search-input-wrapper:hover .search-icon {
    transform: translateY(-50%) scale(1.1);
}

.filter-chip:hover .filter-chip-text {
    transform: scale(1.05);
}

/* Focus states for accessibility */
.search-input:focus {
    outline: none;
}

.sort-select:focus {
    outline: none;
}

/* Custom scrollbar for sort select */
.sort-select::-webkit-scrollbar {
    width: 8px;
}

.sort-select::-webkit-scrollbar-track {
    background: #f1f1f1;
    border-radius: 4px;
}

.sort-select::-webkit-scrollbar-thumb {
    background: #c1c1c1;
    border-radius: 4px;
}

.sort-select::-webkit-scrollbar-thumb:hover {
    background: #a8a8a8;
}
</style>

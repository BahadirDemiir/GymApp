@{
    ViewData["Title"] = "Database Test";
}

<div class="container">
    <h2>Database Connection Test</h2>
    
    <div class="card mb-4">
        <div class="card-header">
            <h5>Connection Status</h5>
        </div>
        <div class="card-body">
            @if (ViewBag.ConnectionStatus == "Connected")
            {
                <div class="alert alert-success">
                    <strong>✅ Database Connected Successfully!</strong>
                </div>
                <p><strong>Total Users:</strong> @ViewBag.UserCount</p>
            }
            else
            {
                <div class="alert alert-danger">
                    <strong>❌ Database Connection Failed!</strong>
                </div>
                <p><strong>Error:</strong> @ViewBag.ErrorMessage</p>
            }
        </div>
    </div>

    @if (ViewBag.Users != null && ViewBag.Users.Count > 0)
    {
        <div class="card">
            <div class="card-header">
                <h5>Users in Database</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Phone</th>
                                <th>Password</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in ViewBag.Users)
                            {
                                <tr>
                                    <td>@user.Id</td>
                                    <td>@user.Name</td>
                                    <td>@user.Email</td>
                                    <td>@user.Phone</td>
                                    <td>@user.Password</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    
    <div class="mt-3">
        <a asp-action="Index" class="btn btn-primary">Back to Home</a>
        <a asp-action="Login" class="btn btn-success">Try Login</a>
        <a asp-action="Register" class="btn btn-info">Register New User</a>
    </div>
</div>

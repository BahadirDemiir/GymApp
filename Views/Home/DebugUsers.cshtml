@model List<GymAppFresh.Models.Member>

@{
    ViewData["Title"] = "Debug Users";
}

<div class="container">
    <h2>Debug: Database Users</h2>
    <p class="text-muted">This view shows all users in the database for debugging purposes.</p>
    
    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Password</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>@user.Id</td>
                            <td>@user.Name</td>
                            <td>@user.Email</td>
                            <td>@user.Phone</td>
                            <td>@user.Password</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-warning">
            No users found in the database.
        </div>
    }
    
    <div class="mt-3">
        <a asp-action="Index" class="btn btn-primary">Back to Home</a>
        <a asp-action="Register" class="btn btn-success">Register New User</a>
    </div>
</div>

@{
    ViewData["Title"] = "GymApp - Spor Salonu Kursları ve Koçlar";
}

@section Styles {
<link rel="stylesheet" href="~/css/site.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
<link rel="stylesheet" href="~/css/index.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/map.css" asp-append-version="true" />
}

<!-- Hero Section -->
<section class="hero-section">
    <div class="hero-content">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-8 col-md-10 col-12 text-center">
                    <h1 class="hero-title">Fitness Yolculuğuna Başla</h1>
                    <p class="hero-subtitle">Türkiye'nin en iyi spor salonlarında, uzman koçlarla birlikte hedeflerine ulaş. Hemen kayıt ol ve fitness macerana başla!</p>
                    <div class="hero-buttons">
                        @if(User.Identity.IsAuthenticated)
                        {
                            <a href="/Recommend" class="btn btn-primary-custom">
                                <i class="bi bi-lightbulb me-2"></i>Program Önerileri
                            </a>
                            <form asp-controller="Home" asp-action="Logout" method="post" class="d-inline">
                                <button type="submit" class="btn btn-primary-custom">
                                    <i class="bi bi-lightbulb me-2"></i> Çıkış Yap
                                </button>
                            </form>

                        }
                        else
                        {
                            <a href="/Home/Register" class="btn btn-primary-custom">
                                <i class="bi bi-person-plus me-2"></i>Hemen Kayıt Ol
                            </a>
                        }
                        <a href="/Course/Courses" class="btn btn-outline-custom">
                            <i class="bi bi-search me-2"></i>Kursları Keşfet
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Features Section -->
<section class="features-section">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">Neden GymApp?</h2>
            <p class="section-subtitle">Fitness yolculuğunda sana en iyi deneyimi sunmak için tasarlandı</p>
        </div>
        
        <div class="row g-4">
            <div class="col-lg-4 col-md-6">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="bi bi-geo-alt"></i>
                    </div>
                    <h4>Geniş Ağ</h4>
                    <p>Türkiye genelinde yüzlerce spor salonu ve binlerce kurs seçeneği</p>
                </div>
            </div>
            
            <div class="col-lg-4 col-md-6">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="bi bi-person-check"></i>
                    </div>
                    <h4>Uzman Koçlar</h4>
                    <p>Sertifikalı ve deneyimli koçlarla güvenli ve etkili antrenman</p>
                </div>
            </div>
            
            <div class="col-lg-4 col-md-6">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="bi bi-calendar-check"></i>
                    </div>
                    <h4>Kolay Kayıt</h4>
                    <p>Tek tıkla kurs kaydı, esnek ödeme seçenekleri ve anlık bildirimler</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Courses Preview Section -->
<section class="courses-section">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">Popüler Kurslar</h2>
            <p class="section-subtitle">En çok tercih edilen fitness kurslarını keşfet</p>
        </div>
        
        <div class="row g-4">
            <div class="col-lg-4 col-md-6">
                <div class="course-card">
                    <div class="course-image">
                        <i class="bi bi-heart-pulse"></i>
                    </div>
                    <div class="course-content">
                        <div class="course-category">Kardiyo</div>
                        <h5 class="course-title">HIIT Antrenmanı</h5>
                        <p class="course-description">Yüksek yoğunluklu interval antrenman ile maksimum yağ yakımı</p>
                        <div class="course-meta">
                            <span><i class="bi bi-clock me-1"></i>45 dk</span>
                            <span><i class="bi bi-star-fill me-1"></i>4.8</span>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-4 col-md-6">
                <div class="course-card">
                    <div class="course-image">
                        <i class="bi bi-lightning"></i>
                    </div>
                    <div class="course-content">
                        <div class="course-category">Güç Antrenmanı</div>
                        <h5 class="course-title">CrossFit</h5>
                        <p class="course-description">Fonksiyonel fitness ile güç, dayanıklılık ve esneklik</p>
                        <div class="course-meta">
                            <span><i class="bi bi-clock me-1"></i>60 dk</span>
                            <span><i class="bi bi-star-fill me-1"></i>4.9</span>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-4 col-md-6">
                <div class="course-card">
                    <div class="course-image">
                        <i class="bi bi-droplet"></i>
                    </div>
                    <div class="course-content">
                        <div class="course-category">Yoga & Pilates</div>
                        <h5 class="course-title">Vinyasa Yoga</h5>
                        <p class="course-description">Nefes ile senkronize akışkan yoga hareketleri</p>
                        <div class="course-meta">
                            <span><i class="bi bi-clock me-1"></i>75 dk</span>
                            <span><i class="bi bi-star-fill me-1"></i>4.7</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="text-center mt-5">
            <a href="/Course/Courses" class="btn btn-primary-custom">
                <i class="bi bi-arrow-right me-2"></i>Tüm Kursları Gör
            </a>
        </div>
    </div>
</section>

<!-- Coaches Preview Section -->
<section class="coaches-section">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">Uzman Koçlarımız</h2>
            <p class="section-subtitle">Deneyimli ve sertifikalı koçlarla fitness hedeflerine ulaş</p>
        </div>
        
        <div class="row g-4">
            <div class="col-lg-3 col-md-6">
                <div class="coach-card">
                    <div class="coach-avatar">
                        <i class="bi bi-person"></i>
                    </div>
                    <h5>Ahmet Yılmaz</h5>
                    <p class="text-muted">Fitness Koçu</p>
                    <div class="d-flex justify-content-center gap-2">
                        <span class="badge bg-primary">Güç Antrenmanı</span>
                        <span class="badge bg-success">5 Yıl Deneyim</span>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-3 col-md-6">
                <div class="coach-card">
                    <div class="coach-avatar">
                        <i class="bi bi-person"></i>
                    </div>
                    <h5>Ayşe Demir</h5>
                    <p class="text-muted">Yoga Eğitmeni</p>
                    <div class="d-flex justify-content-center gap-2">
                        <span class="badge bg-info">Yoga</span>
                        <span class="badge bg-success">3 Yıl Deneyim</span>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-3 col-md-6">
                <div class="coach-card">
                    <div class="coach-avatar">
                        <i class="bi bi-person"></i>
                    </div>
                    <h5>Mehmet Kaya</h5>
                    <p class="text-muted">CrossFit Koçu</p>
                    <div class="d-flex justify-content-center gap-2">
                        <span class="badge bg-warning">CrossFit</span>
                        <span class="badge bg-success">7 Yıl Deneyim</span>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-3 col-md-6">
                <div class="coach-card">
                    <div class="coach-avatar">
                        <i class="bi bi-person"></i>
                    </div>
                    <h5>Zeynep Öz</h5>
                    <p class="text-muted">Pilates Eğitmeni</p>
                    <div class="d-flex justify-content-center gap-2">
                        <span class="badge bg-secondary">Pilates</span>
                        <span class="badge bg-success">4 Yıl Deneyim</span>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="text-center mt-5">
            <a href="/Coach/Coachs" class="btn btn-outline-primary">
                <i class="bi bi-people me-2"></i>Tüm Koçları Gör
            </a>
        </div>
    </div>
</section>


@section Scripts {
    <script src="~/js/index.js"></script>
    <script src="~/js/turkey-map.js"></script>

}

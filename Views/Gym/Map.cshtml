@{
    ViewData["Title"] = "Türkiye Haritası";
}
<link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"/>

@section Styles {
    <link rel="stylesheet" href="~/css/map.css" asp-append-version="true" />

}

<div class="map-wrap">      
  <!-- Sol overlay panel -->
  <div class="overlay-panel">
    <div class="panel-header">
      <div class="search-wrap">
        <input id="searchBox" type="text" placeholder="Mağaza ara (isim/şehir/adres)..." />
        <i class="bi bi-search"></i>
      </div>

      <div class="panel-actions ms-1">
        <!-- Harita Stil Seçici -->
        <div class="dropdown me-2">
          <button class="btn btn-outline-primary btn-sm dropdown-toggle" type="button" id="mapStyleDropdown" data-bs-toggle="dropdown" aria-expanded="false" title="Harita stili">
            <i class="bi bi-palette"></i> Açık Tema
          </button>
          <ul class="dropdown-menu" aria-labelledby="mapStyleDropdown">
            <li><a class="dropdown-item active" href="#" data-style="light">Açık Tema</a></li>
            <li><a class="dropdown-item" href="#" data-style="dark">Koyu Tema</a></li>
            <li><a class="dropdown-item" href="#" data-style="satellite">Uydu Görünümü</a></li>
            <li><a class="dropdown-item" href="#" data-style="streets">Sokak Görünümü</a></li>
          </ul>
        </div>
        
        <button id="panelFilterBtn" class="btn btn-outline-secondary btn-sm" title="Şehir filtresi" aria-expanded="false">
          <i class="bi bi-funnel"></i>
        </button>
        <div id="cityDropdown" class="dropdown-menu-city" hidden>
          <div class="dropdown-title">Şehir filtrele</div>
          <button class="dropdown-item" data-city-id="">Tüm Şehirler</button>
          <div class="dropdown-divider"></div>
          <div id="cityItems"></div>
        </div>
      </div>
    </div>

    <div class="tab-buttons">
      <button class="tab-btn active" data-target="#storeList">Salonlarımız</button>
      <button class="tab-btn" data-target="#nearbyTab">Yakınımdakiler</button>
    </div>

    <div id="storeList" class="tab-content active">
    </div>

    <div id="nearbyTab" class="tab-content">
      <div id="nearbyState" class="muted">Konumun alınıyor… (izin vermen gerekebilir)</div>
      <div id="nearbyList" class="nearby-list" hidden></div>
    </div>
  </div>

  <button id="panelHandle" class="panel-handle" aria-label="Panel toggle">
    <i class="bi bi-chevron-left"></i>
  </button>

  <div id="trMap"></div>
</div>

<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/turkey-map.js" asp-append-version="true"></script>

<script>
  document.querySelectorAll(".tab-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      document.querySelectorAll(".tab-btn").forEach(b => b.classList.remove("active"));
      btn.classList.add("active");
      document.querySelectorAll(".tab-content").forEach(tc => tc.classList.remove("active"));
      const target = document.querySelector(btn.dataset.target);
      target.classList.add("active");

      if (btn.dataset.target === "#nearbyTab") {
        ensureNearbyComputed();
      }
    });
  });


  async function getGyms() {
    if (Array.isArray(window.GYMS) && window.GYMS.length) {
      return window.GYMS; 
    }
    const res = await fetch('/Gym/AllAsJson'); 
    if (!res.ok) throw new Error('Salon listesi alınamadı');
    return await res.json();
  }
  let nearestDone = false;

  function haversineKm(lat1, lon1, lat2, lon2) {
    const R = 6371;
    const dLat = (lat2-lat1) * Math.PI/180;
    const dLon = (lon2-lon1) * Math.PI/180;
    const a = Math.sin(dLat/2)**2 +
              Math.cos(lat1*Math.PI/180) *
              Math.cos(lat2*Math.PI/180) *
              Math.sin(dLon/2)**2;
    const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
    return R * c;
  }

  async function ensureNearbyComputed() {
    if (nearestDone) return;
    const stateEl = document.getElementById('nearbyState');
    const listEl  = document.getElementById('nearbyList');

    let gyms = [];
    try {
      gyms = await getGyms();
      if (!Array.isArray(gyms) || gyms.length === 0) throw new Error();
    } catch {
      stateEl.textContent = 'Salon verisi alınamadı ';
      return;
    }
    if (!navigator.geolocation) {
      stateEl.textContent = 'Tarayıcın konum özelliğini desteklemiyor ';
      return;
    }

    stateEl.textContent = 'Konum alınıyor…';
    navigator.geolocation.getCurrentPosition(async (pos) => {
      const uLat = pos.coords.latitude;
      const uLng = pos.coords.longitude;

      const withDist = gyms
        .filter(g => g.latitude != null && g.longitude != null)
        .map(g => ({
          ...g,
          distanceKm: haversineKm(uLat, uLng, Number(g.latitude), Number(g.longitude))
        }))
        .sort((a,b) => a.distanceKm - b.distanceKm)
        .slice(0,3);

      renderNearby(withDist);
      stateEl.hidden = true;
      listEl.hidden = false;
      nearestDone = true;

    }, (err) => {
      const reason = (err.code === 1) ? 'Konum izni verilmedi' :
                     (err.code === 2) ? 'Konum belirlenemedi' : 'Konum isteği zaman aşımına uğradı';
      stateEl.textContent = reason + ' — Yakındakileri göstermek için konum izni vermelisin ';
    }, { enableHighAccuracy: true, timeout: 10000, maximumAge: 0 });
  }

  function renderNearby(list) {
    const el = document.getElementById('nearbyList');
    el.innerHTML = '';
    if (!list.length) {
      el.innerHTML = '<div class="muted">Yakında salon bulunamadı</div>';
      return;
    }

    list.forEach(g => {
      const div = document.createElement('div');
      div.className = 'nearby-card';
      div.innerHTML = `
        <div>
          <div><strong>${escapeHtml(g.name || 'Salon')}</strong></div>
          <div class="nearby-meta">
            ${(g.city ? g.city + ' • ' : '')}${g.address || ''}
          </div>
          <div class="nearby-meta">
            ~ ${g.distanceKm.toFixed(1)} km
          </div>
        </div>
        <div class="nearby-actions">
          <button class="btn btn-sm btn-outline-primary" data-gym-id="${g.id || g.gymId || ''}">
            <i class="bi bi-geo-alt"></i> Göster
          </button>
        </div>
      `;
      el.appendChild(div);
    });

    el.querySelectorAll('button[data-gym-id]').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.getAttribute('data-gym-id');
        if (typeof window.panToGym === 'function') {
          window.panToGym(id);
        } else if (window.markersById && window.markersById[id]) {
          const m = window.markersById[id];
          const latLng = m.getLatLng();
          if (window.map) {
            window.map.setView(latLng, 15);
            m.openPopup && m.openPopup();
          }
        } else {
          const gym = list.find(x => (x.id || x.gymId || '') == id);
          if (gym && window.map) {
            window.map.setView([gym.latitude, gym.longitude], 15);
          }
        }
      });
    });
  }

  function escapeHtml(s) {
    return String(s ?? '').replace(/[&<>"']/g, m => ({
      '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'
    }[m]));
  }

</script>

@model IEnumerable<GymAppFresh.Models.GymLocation>

@{
    ViewData["Title"] = "Salon Listesi";
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"/>
    <style>
        .gym-list-header {
            background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%);
        }
        
        .filter-section {
            border-bottom: 1px solid #e9ecef;
        }
        
        .table th {
            font-weight: 600;
            color: #495057;
            border-top: none;
            border-bottom: 2px solid #dee2e6;
        }
        
        .table td {
            vertical-align: middle;
            border-top: none;
            border-bottom: 1px solid #f8f9fa;
        }
        
        .table tbody tr:hover {
            background-color: #f8f9fa;
            transform: translateY(-1px);
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            transition: all 0.2s ease;
        }
        
        .btn-group .btn {
            border-radius: 6px !important;
            margin: 0 2px;
        }
        
        .badge {
            font-size: 0.75rem;
            padding: 0.5em 0.75em;
        }
        
        .card {
            border: none;
            border-radius: 12px;
        }
        
        .card-header {
            border-bottom: 1px solid #e9ecef;
            border-radius: 12px 12px 0 0 !important;
        }
        
        .form-select-lg, .form-control-lg {
            border-radius: 8px;
        }
        
        .btn-lg {
            border-radius: 8px;
            padding: 0.75rem 1.5rem;
        }
        
        #noResultsRow td {
            background: #f8f9fa;
        }
        
        .display-4 {
            font-size: 3rem;
            color: #6c757d;
        }
    </style>
}

<!-- Header Section -->
<section class="gym-list-header py-4 bg-primary text-white">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <h1 class="display-6 fw-bold mb-2">
                    <i class="bi bi-building me-3"></i>Spor Salonlarımız
                </h1>
                <p class="lead mb-0">Türkiye genelindeki tüm spor salonlarımızı keşfedin</p>
            </div>
            <div class="col-lg-4 text-lg-end">
                <a href="/Admin/Gym/addGym" class="btn btn-light btn-lg">
                    <i class="bi bi-plus-circle me-2"></i>Yeni Salon Ekle
                </a>
            </div>
        </div>
    </div>
</section>

<!-- Filter Section -->
<section class="filter-section py-3 bg-light">
    <div class="container">
        <div class="row align-items-end">
            <div class="col-md-4">
                <label for="cityFilter" class="form-label fw-bold">
                    <i class="bi bi-geo-alt me-2"></i>Şehir Filtresi
                </label>
                <select id="cityFilter" class="form-select form-select-lg">
                    <option value="">Tüm Şehirler</option>
                    @foreach (var city in ViewBag.Cities)
                    {
                        <option value="@city.CityId">@city.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label for="statusFilter" class="form-label fw-bold">
                    <i class="bi bi-toggle-on me-2"></i>Durum Filtresi
                </label>
                <select id="statusFilter" class="form-select form-select-lg">
                    <option value="">Tüm Durumlar</option>
                    <option value="true">Aktif</option>
                    <option value="false">Pasif</option>
                </select>
            </div>
            <div class="col-md-3">
                <label for="searchFilter" class="form-label fw-bold">
                    <i class="bi bi-search me-2"></i>Arama
                </label>
                <input type="text" id="searchFilter" class="form-control form-control-lg" placeholder="Salon adı ara...">
            </div>
            <div class="col-md-2">
                <button id="clearFilter" class="btn btn-outline-secondary btn-lg w-100">
                    <i class="bi bi-arrow-clockwise me-2"></i>Temizle
                </button>
            </div>
        </div>
    </div>
</section>

<!-- Gym List Section -->
<section class="gym-list-section py-4">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <div class="card shadow-sm">
                    <div class="card-header bg-white">
                        <div class="d-flex justify-content-between align-items-center">
                            <h5 class="mb-0">
                                <i class="bi bi-list-ul me-2"></i>Salon Listesi
                            </h5>
                            <span class="badge bg-primary fs-6" id="gymCount">@Model.Count() Salon</span>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="border-0">
                                            <i class="bi bi-building me-2"></i>Salon Adı
                                        </th>
                                        <th class="border-0">
                                            <i class="bi bi-geo-alt me-2"></i>Şehir
                                        </th>
                                        <th class="border-0">
                                            <i class="bi bi-geo me-2"></i>Koordinat
                                        </th>
                                        <th class="border-0">
                                            <i class="bi bi-clock me-2"></i>Çalışma Saatleri
                                        </th>
                                        <th class="border-0">
                                            <i class="bi bi-people me-2"></i>Üye Sayısı
                                        </th>
                                        <th class="border-0">
                                            <i class="bi bi-toggle-on me-2"></i>Durum
                                        </th>
                                        <th class="border-0">
                                            <i class="bi bi-images me-2"></i>Görseller
                                        </th>
                                        <th class="border-0">
                                            <i class="bi bi-gear me-2"></i>İşlemler
                                        </th>
                                    </tr>
                                </thead>
                                <tbody id="gymTableBody">
                                @foreach (var g in Model)
                                {
                                    <tr data-city-id="@g.CityId" data-status="@g.IsActive.ToString().ToLower()" data-name="@g.Name.ToLower()">
                                        <td class="fw-bold">@g.Name</td>
                                        <td>
                                            <span class="badge bg-info bg-opacity-10 text-info border border-info">
                                                @g.City?.Name
                                            </span>
                                        </td>
                                        <td>
                                            <small class="text-muted">
                                                @g.Latitude.ToString("F4"), @g.Longitude.ToString("F4")
                                            </small>
                                        </td>
                                        <td>
                                            <div class="d-flex flex-column">
                                                <small class="text-muted">
                                                    <i class="bi bi-calendar-week me-1"></i>
                                                    Hafta İçi: @g.OpenTime.ToString(@"hh\:mm") - @g.CloseTime.ToString(@"hh\:mm")
                                                </small>
                                                @if (g.WOpenTime != null && g.WCloseTime != null)
                                                {
                                                    <small class="text-muted">
                                                        <i class="bi bi-calendar2-week me-1"></i>
                                                        Hafta Sonu: @g.WOpenTime.ToString(@"hh\:mm") - @g.WCloseTime.ToString(@"hh\:mm")
                                                    </small>
                                                }
                                            </div>
                                        </td>
                                        <td>
                                            <span class="badge bg-success bg-opacity-10 text-success border border-success">
                                                @g.currentMember üye
                                            </span>
                                        </td>
                                        <td>
                                            @if (g.IsActive)
                                            {
                                                <span class="badge bg-success">
                                                    <i class="bi bi-check-circle me-1"></i>Aktif
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">
                                                    <i class="bi bi-x-circle me-1"></i>Pasif
                                                </span>
                                            }
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(g.Images))
                                            {
                                                <span class="badge bg-primary bg-opacity-10 text-primary border border-primary">
                                                    <i class="bi bi-image me-1"></i>
                                                    @g.Images.Split(',').Length görsel
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-light text-muted border">
                                                    <i class="bi bi-image me-1"></i>Görsel yok
                                                </span>
                                            }
                                        </td>
                                        <td>
                                            <div class="btn-group" role="group">
                                                <a href="/Gym/GymDetails/@g.Id" class="btn btn-sm btn-outline-primary" title="Detaylar">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                                <a href="/Admin/Gym/EditGym/@g.Id" class="btn btn-sm btn-outline-warning" title="Düzenle">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                                <button class="btn btn-sm btn-outline-info" title="Haritada Göster" onclick="showOnMap(@g.Latitude, @g.Longitude)">
                                                    <i class="bi bi-map"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const cityFilter = document.getElementById('cityFilter');
    const statusFilter = document.getElementById('statusFilter');
    const searchFilter = document.getElementById('searchFilter');
    const clearFilter = document.getElementById('clearFilter');
    const gymTableBody = document.getElementById('gymTableBody');
    const allRows = Array.from(gymTableBody.querySelectorAll('tr'));
    const gymCountElement = document.getElementById('gymCount');

    function filterGyms() {
        const selectedCityId = cityFilter.value;
        const selectedStatus = statusFilter.value;
        const searchTerm = searchFilter.value.toLowerCase();
        let visibleCount = 0;
        
        allRows.forEach(row => {
            const cityId = row.getAttribute('data-city-id');
            const status = row.getAttribute('data-status');
            const name = row.getAttribute('data-name');
            
            const cityMatch = !selectedCityId || cityId === selectedCityId;
            const statusMatch = !selectedStatus || status === selectedStatus;
            const searchMatch = !searchTerm || name.includes(searchTerm);
            
            if (cityMatch && statusMatch && searchMatch) {
                row.style.display = '';
                visibleCount++;
            } else {
                row.style.display = 'none';
            }
        });
        
        // Görünen salon sayısını güncelle
        gymCountElement.textContent = `${visibleCount} Salon`;
        
        // Sonuç yoksa mesaj göster
        if (visibleCount === 0) {
            showNoResultsMessage();
        } else {
            hideNoResultsMessage();
        }
    }

    function showNoResultsMessage() {
        let noResultsRow = document.getElementById('noResultsRow');
        if (!noResultsRow) {
            noResultsRow = document.createElement('tr');
            noResultsRow.id = 'noResultsRow';
            noResultsRow.innerHTML = `
                <td colspan="8" class="text-center py-5">
                    <div class="text-muted">
                        <i class="bi bi-search display-4"></i>
                        <h5 class="mt-3">Sonuç Bulunamadı</h5>
                        <p>Seçilen kriterlere uygun salon bulunamadı.</p>
                        <button class="btn btn-outline-primary" onclick="clearAllFilters()">
                            <i class="bi bi-arrow-clockwise me-2"></i>Tüm Filtreleri Temizle
                        </button>
                    </div>
                </td>
            `;
            gymTableBody.appendChild(noResultsRow);
        }
        noResultsRow.style.display = '';
    }

    function hideNoResultsMessage() {
        const noResultsRow = document.getElementById('noResultsRow');
        if (noResultsRow) {
            noResultsRow.style.display = 'none';
        }
    }

    function clearAllFilters() {
        cityFilter.value = '';
        statusFilter.value = '';
        searchFilter.value = '';
        filterGyms();
    }

    // Event listeners
    cityFilter.addEventListener('change', filterGyms);
    statusFilter.addEventListener('change', filterGyms);
    searchFilter.addEventListener('input', filterGyms);
    
    clearFilter.addEventListener('click', clearAllFilters);
    
    // Global function for map integration
    window.showOnMap = function(lat, lng) {
        // Harita sayfasına yönlendir veya modal aç
        const url = `/Gym/Map?lat=${lat}&lng=${lng}`;
        window.open(url, '_blank');
    };
    
    // Initial filter
    filterGyms();
});
</script>

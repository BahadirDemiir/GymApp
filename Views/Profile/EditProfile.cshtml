@model GymAppFresh.Models.ViewModel.EditProfileViewModel

@{
    ViewData["Title"] = "Profil Güncelleme";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-person-gear me-2"></i>Profil Güncelleme
                    </h4>
                </div>
                <div class="card-body p-4">
                    
                    <form asp-controller="Profile" asp-action="EditProfile" method="post">
                        <input type="hidden" asp-for="Id" value="@Model.Id">
                        
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                        
                        <div class="mb-3">
                            <label asp-for="Phone" class="form-label">
                                <i class="bi bi-telephone-fill me-1"></i>Telefon Numarası
                            </label>
                            <input asp-for="Phone" class="form-control" placeholder="Telefon numaranızı giriniz">
                            <span asp-validation-for="Phone" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Weight" class="form-label">
                                <i class="bi bi-speedometer2 me-1"></i>Kilo (kg)
                            </label>
                            <input asp-for="Weight" class="form-control" type="number" step="0.1" placeholder="Kilonuzu giriniz">
                            <span asp-validation-for="Weight" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="GymLocationId" class="form-label">
                                <i class="bi bi-geo-alt-fill me-1"></i>Spor Salonu
                            </label>
                            <select asp-for="GymLocationId" class="form-select" asp-items="@(new SelectList(ViewBag.GymLocations, "Value", "Text"))">
                                <option value="">Spor salonu seçiniz</option>
                            </select>
                            <span asp-validation-for="GymLocationId" class="text-danger"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle me-1"></i>Güncelle
                            </button>
                            <a asp-controller="Profile" asp-action="Profile" class="btn btn-secondary">
                                <i class="bi bi-arrow-left me-1"></i>Geri Dön
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
@model List<MemberThreadListItemVM>
@{
    ViewData["Title"] = "Mesajlarım";
    var hasData = Model != null && Model.Any();
}

<div class="chat-inbox-container">
    <!-- Modern Header with Gradient Background -->
    <div class="chat-header">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-12">
                    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
                        <!-- Title Section -->
                        <div class="d-flex align-items-center gap-3">
                            <a href="/" class="back-button">
                                <i class="bi bi-arrow-left"></i>
                            </a>
                            <div class="chat-icon-wrapper">
                                <i class="bi bi-chat-dots-fill"></i>
                            </div>
                            <div>
                                <h1 class="chat-title mb-0">Mesajlarım</h1>
                                @if (hasData)
                                {
                                    <p class="chat-subtitle mb-0">@Model.Count sohbet</p>
                                }
                                else
                                {
                                    <p class="chat-subtitle mb-0">Henüz sohbet yok</p>
                                }
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="d-flex align-items-center gap-2 flex-wrap">
                            <!-- Search -->
                            <div class="search-container">
                                <div class="search-input-wrapper">
                                    <i class="bi bi-search search-icon"></i>
                                    <input id="searchBox" class="search-input" placeholder="PT adı veya #ID ara…" />
                                </div>
                            </div>

                            <!-- Sort Dropdown -->
                            <div class="dropdown">
                                <button class="btn btn-sort dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-sort-down"></i>
                                    <span class="d-none d-sm-inline">Sırala</span>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end sort-dropdown">
                                    <li><button class="dropdown-item sort-item" data-sort="newest">
                                        <i class="bi bi-arrow-up-circle me-2"></i>En yeni
                                    </button></li>
                                    <li><button class="dropdown-item sort-item" data-sort="oldest">
                                        <i class="bi bi-arrow-down-circle me-2"></i>En eski
                                    </button></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><button class="dropdown-item sort-item" data-sort="unread">
                                        <i class="bi bi-circle-fill me-2 text-warning"></i>Önce okunmamış
                                    </button></li>
                                </ul>
                            </div>

                            <!-- New Chat Button -->
                            <a href="/Chat/StaffList" class="btn btn-new-chat">
                                <i class="bi bi-plus-lg me-1"></i>
                                <span class="d-none d-sm-inline">Yeni Sohbet</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="container chat-content">

        <!-- Empty state -->
        @if (!hasData)
        {
            <div class="empty-state">
                <div class="empty-state-content">
                    <div class="empty-state-icon">
                        <i class="bi bi-chat-dots"></i>
                    </div>
                    <h3 class="empty-state-title">Henüz sohbet yok</h3>
                    <p class="empty-state-description">
                        Koçlarınızla iletişime geçmek için yeni bir sohbet başlatın.<br>
                        "Merhaba koç! 👋" diyerek başlayabilirsiniz.
                    </p>
                    <a href="/Chat/StaffList" class="btn btn-empty-state">
                        <i class="bi bi-plus-circle me-2"></i>
                        Yeni Sohbet Başlat
                    </a>
                </div>
            </div>
        }
        else
        {
            <!-- Threads List -->
            <div class="threads-container">
                <div class="threads-list" id="threadList">
                    @foreach (var x in Model)
                    {
                        var initials = string.IsNullOrWhiteSpace(x.StaffName) ? "#" : x.StaffName.Trim()[0].ToString().ToUpper();
                        var lastAtLocal = x.LastAt.ToLocalTime();
                        var isUnread = x.UnreadForMember > 0;
                        var timeAgo = GetTimeAgo(lastAtLocal);

                        <a class="thread-item @(isUnread ? "unread" : "")"
                           asp-controller="Chat" asp-action="Thread" asp-route-staffId="@x.StaffId"
                           data-lastat="@lastAtLocal.Ticks"
                           data-unread="@x.UnreadForMember"
                           data-name="@x.StaffName.ToLower()"
                           data-id="@x.StaffId">
                            
                            <!-- Avatar Section -->
                            <div class="thread-avatar">
                                <div class="avatar-circle @(isUnread ? "unread" : "")">
                                    <span class="avatar-text">@initials</span>
                                </div>
                                @if (isUnread)
                                {
                                    <div class="online-indicator"></div>
                                }
                            </div>

                            <!-- Content Section -->
                            <div class="thread-content">
                                <div class="thread-header">
                                    <div class="thread-name-section">
                                        <h6 class="thread-name">@x.StaffName</h6>
                                        <span class="thread-id">#@x.StaffId</span>
                                    </div>
                                    <div class="thread-meta">
                                        <span class="thread-time">@timeAgo</span>
                                        @if (isUnread)
                                        {
                                            <div class="unread-badge">
                                                <span class="unread-count">@x.UnreadForMember</span>
                                            </div>
                                        }
                                    </div>
                                </div>
                                
                                <div class="thread-preview">
                                    <p class="thread-message @(isUnread ? "unread" : "")">
                                        @(string.IsNullOrWhiteSpace(x.LastMessage) ? "Henüz mesaj yok." : x.LastMessage)
                                    </p>
                                </div>
                            </div>

                            <!-- Action Arrow -->
                            <div class="thread-action">
                                <i class="bi bi-chevron-right"></i>
                            </div>
                        </a>
                    }
                </div>
            </div>
        }
    </div>
</div>

@functions {
    string GetTimeAgo(DateTime dateTime)
    {
        var timeSpan = DateTime.Now - dateTime;
        
        if (timeSpan.TotalMinutes < 1)
            return "Şimdi";
        else if (timeSpan.TotalMinutes < 60)
            return $"{(int)timeSpan.TotalMinutes} dk";
        else if (timeSpan.TotalHours < 24)
            return $"{(int)timeSpan.TotalHours} sa";
        else if (timeSpan.TotalDays < 7)
            return $"{(int)timeSpan.TotalDays} gün";
        else
            return dateTime.ToString("dd MMM");
    }
}
</div>

@section Scripts {
    <script>
        (() => {
            const list = document.getElementById("threadList");
            const search = document.getElementById("searchBox");

            // Live search with enhanced UX
            function filter() {
                if (!list) return;
                const q = (search?.value || "").trim().toLowerCase();
                const items = list.querySelectorAll(".thread-item");
                let visibleCount = 0;
                
                items.forEach(item => {
                    const txt = item.textContent.toLowerCase();
                    const show = !q || txt.includes(q);
                    item.style.display = show ? "" : "none";
                    if (show) visibleCount++;
                });

                // Show no results message
                const existingHint = document.getElementById("noResultsHint");
                if (visibleCount === 0 && q) {
                    if (!existingHint) {
                        const hint = document.createElement("div");
                        hint.id = "noResultsHint";
                        hint.className = "no-results-message";
                        hint.innerHTML = `
                            <div class="no-results-icon">
                                <i class="bi bi-search"></i>
                            </div>
                            <h6>Sonuç bulunamadı</h6>
                            <p>"${q}" için arama sonucu bulunamadı.</p>
                        `;
                        list?.appendChild(hint);
                    }
                } else {
                    existingHint?.remove();
                }
            }

            // Enhanced search with debouncing
            let searchTimeout;
            search?.addEventListener("input", (e) => {
                clearTimeout(searchTimeout);
                searchTimeout = setTimeout(filter, 300);
            });

            // Sorting with visual feedback
            function sortBy(mode) {
                if (!list) return;
                const rows = Array.from(list.querySelectorAll(".thread-item"));
                
                rows.sort((a, b) => {
                    const at = Number(a.dataset.lastat || 0);
                    const bt = Number(b.dataset.lastat || 0);
                    const au = Number(a.dataset.unread || 0);
                    const bu = Number(b.dataset.unread || 0);

                    if (mode === "unread") {
                        if (bu !== au) return bu - au;
                        return bt - at;
                    }
                    if (mode === "oldest") return at - bt;
                    return bt - at;
                });

                // Animate sorting
                rows.forEach((row, index) => {
                    setTimeout(() => {
                        list.appendChild(row);
                    }, index * 50);
                });
            }

            // Sort button interactions
            document.querySelectorAll(".sort-item").forEach(btn => {
                btn.addEventListener("click", (e) => {
                    e.preventDefault();
                    sortBy(btn.dataset.sort);
                    
                    // Update active state
                    document.querySelectorAll(".sort-item").forEach(b => b.classList.remove("active"));
                    btn.classList.add("active");
                });
            });

            // Default sort
            sortBy("newest");

            // Enhanced keyboard navigation
            let idx = -1;
            function getVisibleItems() {
                return Array.from(list?.querySelectorAll('.thread-item'))
                    .filter(el => el.style.display !== 'none');
            }

            function highlightItem(n) {
                const items = getVisibleItems();
                items.forEach(el => el.classList.remove('keyboard-active'));
                
                if (!items.length) return;
                if (n < 0) n = 0;
                if (n >= items.length) n = items.length - 1;
                
                items[n].classList.add('keyboard-active');
                items[n].scrollIntoView({ block: 'nearest', behavior: 'smooth' });
                idx = n;
            }

            // Keyboard event handling
            document.addEventListener('keydown', (e) => {
                if (!list) return;
                
                if (e.key === 'ArrowDown') { 
                    e.preventDefault(); 
                    highlightItem(idx + 1); 
                }
                if (e.key === 'ArrowUp') { 
                    e.preventDefault(); 
                    highlightItem(idx - 1); 
                }
                if (e.key === 'Enter' && idx >= 0) {
                    const el = getVisibleItems()[idx];
                    if (el) el.click();
                }
            });

            // Focus management
            search?.addEventListener('focus', () => {
                document.querySelectorAll('.thread-item').forEach(item => {
                    item.classList.remove('keyboard-active');
                });
                idx = -1;
            });
        })();
    </script>
}

<style>
    /* ===== CHAT INBOX MODERN DESIGN ===== */
    
    /* Hide the main navigation */
    .gym-navbar {
        display: none !important;
    }
    
    .main-content {
        margin-top: 0 !important;
    }
    
    .chat-inbox-container {
        min-height: 100vh;
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        margin-top: 0;
        padding-top: 0;
    }

    /* Header Section */
    .chat-header {
        background: var(--gradient-primary);
        padding: 2rem 0;
        margin-bottom: 2rem;
        box-shadow: 0 4px 20px rgba(31, 9, 84, 0.15);
        position: relative;
        z-index: 1000;
    }

    .chat-icon-wrapper {
        width: 60px;
        height: 60px;
        background: rgba(255, 255, 255, 0.15);
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(10px);
    }

    .chat-icon-wrapper i {
        font-size: 1.5rem;
        color: white;
    }

    .chat-title {
        color: white;
        font-family: "Orbitron", sans-serif;
        font-weight: 700;
        font-size: 2rem;
    }

    .chat-subtitle {
        color: rgba(255, 255, 255, 0.8);
        font-size: 0.95rem;
        margin-top: 0.25rem;
    }

    /* Back Button */
    .back-button {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 44px;
        height: 44px;
        background: rgba(255, 255, 255, 0.15);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 12px;
        color: white;
        text-decoration: none;
        transition: all 0.3s ease;
        backdrop-filter: blur(10px);
    }

    .back-button:hover {
        background: rgba(255, 255, 255, 0.25);
        color: white;
        transform: translateX(-2px);
        text-decoration: none;
    }

    .back-button i {
        font-size: 1.2rem;
    }

    /* Search Container */
    .search-container {
        position: relative;
        min-width: 280px;
    }

    .search-input-wrapper {
        position: relative;
        background: rgba(255, 255, 255, 0.15);
        border-radius: 12px;
        border: 1px solid rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(10px);
        transition: all 0.3s ease;
    }

    .search-input-wrapper:focus-within {
        background: rgba(255, 255, 255, 0.25);
        border-color: rgba(255, 255, 255, 0.4);
        box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.1);
    }

    .search-icon {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: rgba(255, 255, 255, 0.7);
        font-size: 0.9rem;
    }

    .search-input {
        background: transparent;
        border: none;
        color: white;
        padding: 0.75rem 1rem 0.75rem 2.5rem;
        width: 100%;
        font-size: 0.9rem;
    }

    .search-input::placeholder {
        color: rgba(255, 255, 255, 0.6);
    }

    .search-input:focus {
        outline: none;
        box-shadow: none;
    }

    /* Buttons */
    .btn-sort {
        background: rgba(255, 255, 255, 0.15);
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: white;
        border-radius: 10px;
        padding: 0.5rem 1rem;
        font-size: 0.9rem;
        transition: all 0.3s ease;
        backdrop-filter: blur(10px);
    }

    .btn-sort:hover {
        background: rgba(255, 255, 255, 0.25);
        color: white;
        transform: translateY(-1px);
    }

    .btn-new-chat {
        background: var(--gradient-light);
        border: none;
        color: white;
        border-radius: 12px;
        padding: 0.75rem 1.5rem;
        font-weight: 600;
        font-size: 0.9rem;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(61, 122, 253, 0.3);
    }

    .btn-new-chat:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(61, 122, 253, 0.4);
        color: white;
    }

    /* Dropdown */
    .sort-dropdown {
        background: rgba(31, 9, 84, 0.95);
        backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 12px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
    }

    .sort-dropdown .dropdown-item {
        color: rgba(255, 255, 255, 0.9);
        padding: 0.75rem 1rem;
        transition: all 0.3s ease;
        border-radius: 8px;
        margin: 0.25rem;
    }

    .sort-dropdown .dropdown-item:hover {
        background: var(--primary-light);
        color: var(--primary-dark);
        transform: translateX(4px);
    }

    .sort-dropdown .dropdown-item.active {
        background: var(--primary-light);
        color: var(--primary-dark);
        font-weight: 600;
    }

    /* Content Area */
    .chat-content {
        padding: 0 1rem 2rem;
    }

    /* Empty State */
    .empty-state {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 400px;
        padding: 2rem;
    }

    .empty-state-content {
        text-align: center;
        max-width: 400px;
    }

    .empty-state-icon {
        width: 120px;
        height: 120px;
        background: var(--gradient-light);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 2rem;
        box-shadow: 0 8px 32px rgba(61, 122, 253, 0.2);
    }

    .empty-state-icon i {
        font-size: 3rem;
        color: white;
    }

    .empty-state-title {
        color: var(--primary-dark);
        font-weight: 700;
        margin-bottom: 1rem;
        font-size: 1.5rem;
    }

    .empty-state-description {
        color: #6c757d;
        margin-bottom: 2rem;
        line-height: 1.6;
    }

    .btn-empty-state {
        background: var(--gradient-primary);
        border: none;
        color: white;
        border-radius: 12px;
        padding: 1rem 2rem;
        font-weight: 600;
        font-size: 1rem;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(61, 122, 253, 0.3);
    }

    .btn-empty-state:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(61, 122, 253, 0.4);
        color: white;
    }

    /* Threads Container */
    .threads-container {
        background: white;
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        overflow: hidden;
        border: 1px solid rgba(0, 0, 0, 0.05);
    }

    .threads-list {
        display: flex;
        flex-direction: column;
    }

    /* Thread Item */
    .thread-item {
        display: flex;
        align-items: center;
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid #f1f3f4;
        text-decoration: none;
        color: inherit;
        transition: all 0.3s ease;
        position: relative;
    }

    .thread-item:last-child {
        border-bottom: none;
    }

    .thread-item:hover {
        background: linear-gradient(135deg, rgba(61, 122, 253, 0.05) 0%, rgba(38, 247, 253, 0.05) 100%);
        transform: translateX(4px);
        text-decoration: none;
        color: inherit;
    }

    .thread-item.unread {
        background: linear-gradient(135deg, rgba(61, 122, 253, 0.08) 0%, rgba(38, 247, 253, 0.08) 100%);
        border-left: 4px solid var(--primary-medium);
    }

    .thread-item.keyboard-active {
        background: linear-gradient(135deg, rgba(61, 122, 253, 0.1) 0%, rgba(38, 247, 253, 0.1) 100%);
        outline: 2px solid var(--primary-medium);
        outline-offset: -2px;
    }

    /* Avatar */
    .thread-avatar {
        position: relative;
        margin-right: 1rem;
        flex-shrink: 0;
    }

    .avatar-circle {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--gradient-light);
        color: white;
        font-weight: 700;
        font-size: 1.1rem;
        box-shadow: 0 4px 12px rgba(61, 122, 253, 0.3);
        transition: all 0.3s ease;
    }

    .avatar-circle.unread {
        background: var(--gradient-primary);
        box-shadow: 0 6px 16px rgba(61, 122, 253, 0.4);
        animation: pulse 2s infinite;
    }

    .online-indicator {
        position: absolute;
        bottom: 2px;
        right: 2px;
        width: 16px;
        height: 16px;
        background: #28a745;
        border: 3px solid white;
        border-radius: 50%;
        animation: pulse 2s infinite;
    }

    /* Thread Content */
    .thread-content {
        flex: 1;
        min-width: 0;
    }

    .thread-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 0.5rem;
    }

    .thread-name-section {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        min-width: 0;
    }

    .thread-name {
        font-weight: 600;
        font-size: 1rem;
        color: var(--primary-dark);
        margin: 0;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .thread-item.unread .thread-name {
        font-weight: 700;
    }

    .thread-id {
        color: #6c757d;
        font-size: 0.8rem;
        font-weight: 500;
        background: #f8f9fa;
        padding: 0.2rem 0.5rem;
        border-radius: 6px;
    }

    .thread-meta {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 0.5rem;
    }

    .thread-time {
        color: #6c757d;
        font-size: 0.8rem;
        font-weight: 500;
    }

    .unread-badge {
        background: var(--gradient-primary);
        border-radius: 12px;
        padding: 0.25rem 0.5rem;
        min-width: 24px;
        text-align: center;
    }

    .unread-count {
        color: white;
        font-size: 0.75rem;
        font-weight: 700;
    }

    .thread-preview {
        margin-top: 0.25rem;
    }

    .thread-message {
        color: #6c757d;
        font-size: 0.9rem;
        margin: 0;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        line-height: 1.4;
    }

    .thread-item.unread .thread-message {
        color: var(--primary-dark);
        font-weight: 500;
    }

    /* Thread Action */
    .thread-action {
        margin-left: 1rem;
        color: #6c757d;
        font-size: 0.9rem;
        transition: all 0.3s ease;
    }

    .thread-item:hover .thread-action {
        color: var(--primary-medium);
        transform: translateX(4px);
    }

    /* No Results Message */
    .no-results-message {
        text-align: center;
        padding: 3rem 2rem;
        color: #6c757d;
    }

    .no-results-icon {
        font-size: 3rem;
        color: #dee2e6;
        margin-bottom: 1rem;
    }

    .no-results-message h6 {
        color: var(--primary-dark);
        font-weight: 600;
        margin-bottom: 0.5rem;
    }

    /* Animations */
    @@keyframes pulse {
        0% { transform: scale(1); }
        50% { transform: scale(1.05); }
        100% { transform: scale(1); }
    }

    /* Responsive Design */
    @@media (max-width: 768px) {
        .chat-header {
            padding: 1.5rem 0;
        }

        .chat-title {
            font-size: 1.5rem;
        }

        .search-container {
            min-width: 200px;
        }

        .thread-item {
            padding: 1rem;
        }

        .avatar-circle {
            width: 48px;
            height: 48px;
            font-size: 1rem;
        }

        .thread-name {
            font-size: 0.9rem;
        }

        .thread-message {
            font-size: 0.85rem;
        }
    }

    @@media (max-width: 576px) {
        .chat-content {
            padding: 0 0.5rem 1rem;
        }

        .thread-item {
            padding: 0.75rem;
        }

        .thread-avatar {
            margin-right: 0.75rem;
        }

        .avatar-circle {
            width: 44px;
            height: 44px;
            font-size: 0.9rem;
        }
    }
</style>

@model List<StaffListItemVM>
@{
    ViewData["Title"] = "PT Listesi";
    var hasStaff = Model != null && Model.Any();
}

<div class="staff-list-container">
    <!-- Modern Header with Gradient Background -->
    <div class="staff-header">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-12">
                    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
                        <!-- Title Section -->
                        <div class="d-flex align-items-center gap-3">
                            <a href="/Chat/Inbox" class="back-button">
                                <i class="bi bi-arrow-left"></i>
                            </a>
                            <div class="staff-icon-wrapper">
                                <i class="bi bi-people-fill"></i>
                            </div>
                            <div>
                                <h1 class="staff-title mb-0">PT'lerim</h1>
                                @if (hasStaff)
                                {
                                    <p class="staff-subtitle mb-0">@Model.Count kişisel antrenör</p>
                                }
                                else
                                {
                                    <p class="staff-subtitle mb-0">Henüz PT bulunmuyor</p>
                                }
                            </div>
                        </div>

                        <!-- Search Section -->
                        <div class="search-container">
                            <div class="search-input-wrapper">
                                <i class="bi bi-search search-icon"></i>
                                <input id="searchBox" class="search-input" placeholder="PT ara… (isim/ID)" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="container staff-content">
        <!-- Error Message -->
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-modern">
                <div class="alert-icon">
                    <i class="bi bi-exclamation-triangle"></i>
                </div>
                <div class="alert-content">
                    <h6 class="alert-title">Uyarı</h6>
                    <p class="alert-message mb-0">@TempData["Error"]</p>
                </div>
            </div>
        }

        <!-- Staff List or Empty State -->
        @if (!hasStaff)
        {
            <div class="empty-state">
                <div class="empty-state-content">
                    <div class="empty-state-icon">
                        <i class="bi bi-person-x"></i>
                    </div>
                    <h3 class="empty-state-title">PT Bulunamadı</h3>
                    <p class="empty-state-description">
                        Bu salonda kayıtlı kişisel antrenör bulunmuyor.<br>
                        Lütfen daha sonra tekrar kontrol edin.
                    </p>
                    <a href="/" class="btn btn-empty-state">
                        <i class="bi bi-house me-2"></i>
                        Ana Sayfaya Dön
                    </a>
                </div>
            </div>
        }
        else
        {
            <!-- Staff Grid -->
            <div class="staff-grid" id="staffList">
                @foreach (var s in Model)
                {
                    var initials = s.StaffName.Substring(0, 1).ToUpper();
                    var isOnline = new Random().Next(0, 2) == 1; // Simulated online status
                    
                    <div class="staff-card">
                        <div class="staff-card-header">
                            <div class="staff-avatar">
                                <div class="avatar-circle">
                                    <span class="avatar-text">@initials</span>
                                </div>
                                @if (isOnline)
                                {
                                    <div class="online-indicator"></div>
                                }
                            </div>
                            <div class="staff-status">
                                @if (isOnline)
                                {
                                    <span class="status-badge online">Çevrimiçi</span>
                                }
                                else
                                {
                                    <span class="status-badge offline">Çevrimdışı</span>
                                }
                            </div>
                        </div>

                        <div class="staff-card-body">
                            <h5 class="staff-name">@s.StaffName</h5>
                            <p class="staff-location">
                                <i class="bi bi-geo-alt me-1"></i>
                                @s.GymLocationName
                            </p>
                            <div class="staff-specialties">
                                <span class="specialty-tag">Fitness</span>
                                <span class="specialty-tag">Kardiyo</span>
                                <span class="specialty-tag">Güç</span>
                            </div>
                        </div>

                        <div class="staff-card-footer">
                            <a class="btn btn-message" 
                               asp-controller="Chat" asp-action="Thread" asp-route-staffId="@s.StaffId">
                                <i class="bi bi-chat-dots me-1"></i>
                                Mesaj Gönder
                            </a>
                        </div>
                    </div>
                }
            </div>

            <!-- No Results Message (Hidden by default) -->
            <div id="noResultsMessage" class="no-results-message" style="display: none;">
                <div class="no-results-icon">
                    <i class="bi bi-search"></i>
                </div>
                <h6>Sonuç bulunamadı</h6>
                <p>Aradığınız kriterlere uygun PT bulunamadı.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
<script>
    (() => {
        const search = document.getElementById("searchBox");
        const list = document.getElementById("staffList");
        const noResultsMessage = document.getElementById("noResultsMessage");

        // Enhanced search with debouncing and better UX
        function performSearch() {
            if (!list) return;
            
            const query = (search?.value || "").trim().toLowerCase();
            const staffCards = list.querySelectorAll(".staff-card");
            let visibleCount = 0;

            staffCards.forEach(card => {
                const text = card.textContent.toLowerCase();
                const isVisible = !query || text.includes(query);
                
                card.style.display = isVisible ? "" : "none";
                if (isVisible) visibleCount++;
            });

            // Show/hide no results message
            if (visibleCount === 0 && query) {
                noResultsMessage?.style.setProperty("display", "block");
            } else {
                noResultsMessage?.style.setProperty("display", "none");
            }
        }

        // Debounced search
        let searchTimeout;
        search?.addEventListener("input", () => {
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(performSearch, 300);
        });

        // Initialize search on page load
        performSearch();

        // Add smooth animations to cards
        const observerOptions = {
            threshold: 0.1,
            rootMargin: '0px 0px -50px 0px'
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('animate-in');
                }
            });
        }, observerOptions);

        // Observe staff cards for animation
        document.querySelectorAll('.staff-card').forEach(card => {
            observer.observe(card);
        });
    })();
</script>
}

<style>
    /* ===== STAFF LIST MODERN DESIGN ===== */
    
    /* Hide the main navigation */
    .gym-navbar {
        display: none !important;
    }
    
    .main-content {
        margin-top: 0 !important;
    }
    
    .staff-list-container {
        min-height: 100vh;
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        margin-top: 0;
        padding-top: 0;
    }

    /* Header Section */
    .staff-header {
        background: var(--gradient-primary);
        padding: 2rem 0;
        margin-bottom: 2rem;
        box-shadow: 0 4px 20px rgba(31, 9, 84, 0.15);
        position: relative;
        z-index: 1000;
    }

    .staff-icon-wrapper {
        width: 60px;
        height: 60px;
        background: rgba(255, 255, 255, 0.15);
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(10px);
    }

    .staff-icon-wrapper i {
        font-size: 1.5rem;
        color: white;
    }

    .staff-title {
        color: white;
        font-family: "Orbitron", sans-serif;
        font-weight: 700;
        font-size: 2rem;
    }

    .staff-subtitle {
        color: rgba(255, 255, 255, 0.8);
        font-size: 0.95rem;
        margin-top: 0.25rem;
    }

    /* Back Button */
    .back-button {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 44px;
        height: 44px;
        background: rgba(255, 255, 255, 0.15);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 12px;
        color: white;
        text-decoration: none;
        transition: all 0.3s ease;
        backdrop-filter: blur(10px);
    }

    .back-button:hover {
        background: rgba(255, 255, 255, 0.25);
        color: white;
        transform: translateX(-2px);
        text-decoration: none;
    }

    .back-button i {
        font-size: 1.2rem;
    }

    /* Search Container */
    .search-container {
        position: relative;
        min-width: 300px;
    }

    .search-input-wrapper {
        position: relative;
        background: rgba(255, 255, 255, 0.15);
        border-radius: 12px;
        border: 1px solid rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(10px);
        transition: all 0.3s ease;
    }

    .search-input-wrapper:focus-within {
        background: rgba(255, 255, 255, 0.25);
        border-color: rgba(255, 255, 255, 0.4);
        box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.1);
    }

    .search-icon {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: rgba(255, 255, 255, 0.7);
        font-size: 0.9rem;
    }

    .search-input {
        background: transparent;
        border: none;
        color: white;
        padding: 0.75rem 1rem 0.75rem 2.5rem;
        width: 100%;
        font-size: 0.9rem;
    }

    .search-input::placeholder {
        color: rgba(255, 255, 255, 0.6);
    }

    .search-input:focus {
        outline: none;
        box-shadow: none;
    }

    /* Content Area */
    .staff-content {
        padding: 0 1rem 2rem;
    }

    /* Modern Alert */
    .alert-modern {
        background: linear-gradient(135deg, #fff3cd 0%, #ffeaa7 100%);
        border: 1px solid #ffc107;
        border-radius: 12px;
        padding: 1rem 1.5rem;
        margin-bottom: 2rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        box-shadow: 0 4px 12px rgba(255, 193, 7, 0.2);
    }

    .alert-icon {
        width: 40px;
        height: 40px;
        background: #ffc107;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1.2rem;
    }

    .alert-content {
        flex: 1;
    }

    .alert-title {
        color: #856404;
        font-weight: 600;
        margin-bottom: 0.25rem;
    }

    .alert-message {
        color: #856404;
        margin: 0;
    }

    /* Empty State */
    .empty-state {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 400px;
        padding: 2rem;
    }

    .empty-state-content {
        text-align: center;
        max-width: 400px;
    }

    .empty-state-icon {
        width: 120px;
        height: 120px;
        background: var(--gradient-light);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 2rem;
        box-shadow: 0 8px 32px rgba(61, 122, 253, 0.2);
    }

    .empty-state-icon i {
        font-size: 3rem;
        color: white;
    }

    .empty-state-title {
        color: var(--primary-dark);
        font-weight: 700;
        margin-bottom: 1rem;
        font-size: 1.5rem;
    }

    .empty-state-description {
        color: #6c757d;
        margin-bottom: 2rem;
        line-height: 1.6;
    }

    .btn-empty-state {
        background: var(--gradient-primary);
        border: none;
        color: white;
        border-radius: 12px;
        padding: 1rem 2rem;
        font-weight: 600;
        font-size: 1rem;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(61, 122, 253, 0.3);
        text-decoration: none;
    }

    .btn-empty-state:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(61, 122, 253, 0.4);
        color: white;
        text-decoration: none;
    }

    /* Staff Grid */
    .staff-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    /* Staff Card */
    .staff-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        border: 1px solid rgba(0, 0, 0, 0.05);
        overflow: hidden;
        transition: all 0.3s ease;
        opacity: 0;
        transform: translateY(20px);
    }

    .staff-card.animate-in {
        opacity: 1;
        transform: translateY(0);
    }

    .staff-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.12);
    }

    .staff-card-header {
        padding: 1.5rem 1.5rem 1rem;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
    }

    .staff-avatar {
        position: relative;
    }

    .avatar-circle {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--gradient-light);
        color: white;
        font-weight: 700;
        font-size: 1.5rem;
        box-shadow: 0 4px 12px rgba(61, 122, 253, 0.3);
        transition: all 0.3s ease;
    }

    .online-indicator {
        position: absolute;
        bottom: 2px;
        right: 2px;
        width: 18px;
        height: 18px;
        background: #28a745;
        border: 3px solid white;
        border-radius: 50%;
        animation: pulse 2s infinite;
    }

    .staff-status {
        margin-top: 0.5rem;
    }

    .status-badge {
        padding: 0.25rem 0.75rem;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .status-badge.online {
        background: rgba(40, 167, 69, 0.1);
        color: #28a745;
        border: 1px solid rgba(40, 167, 69, 0.2);
    }

    .status-badge.offline {
        background: rgba(108, 117, 125, 0.1);
        color: #6c757d;
        border: 1px solid rgba(108, 117, 125, 0.2);
    }

    .staff-card-body {
        padding: 0 1.5rem 1rem;
    }

    .staff-name {
        color: var(--primary-dark);
        font-weight: 700;
        font-size: 1.25rem;
        margin-bottom: 0.5rem;
    }

    .staff-location {
        color: #6c757d;
        font-size: 0.9rem;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
    }

    .staff-specialties {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .specialty-tag {
        background: linear-gradient(135deg, rgba(61, 122, 253, 0.1) 0%, rgba(38, 247, 253, 0.1) 100%);
        color: var(--primary-medium);
        padding: 0.25rem 0.75rem;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
        border: 1px solid rgba(61, 122, 253, 0.2);
    }

    .staff-card-footer {
        padding: 1rem 1.5rem 1.5rem;
        border-top: 1px solid #f1f3f4;
    }

    .btn-message {
        background: var(--gradient-primary);
        border: none;
        color: white;
        border-radius: 12px;
        padding: 0.75rem 1.5rem;
        font-weight: 600;
        font-size: 0.9rem;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(61, 122, 253, 0.3);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 100%;
    }

    .btn-message:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(61, 122, 253, 0.4);
        color: white;
        text-decoration: none;
    }

    /* No Results Message */
    .no-results-message {
        text-align: center;
        padding: 3rem 2rem;
        color: #6c757d;
        background: white;
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    }

    .no-results-icon {
        font-size: 3rem;
        color: #dee2e6;
        margin-bottom: 1rem;
    }

    .no-results-message h6 {
        color: var(--primary-dark);
        font-weight: 600;
        margin-bottom: 0.5rem;
    }

    /* Animations */
    @@keyframes pulse {
        0% { transform: scale(1); }
        50% { transform: scale(1.05); }
        100% { transform: scale(1); }
    }

    /* Responsive Design */
    @@media (max-width: 768px) {
        .staff-header {
            padding: 1.5rem 0;
        }

        .staff-title {
            font-size: 1.5rem;
        }

        .search-container {
            min-width: 250px;
        }

        .staff-grid {
            grid-template-columns: 1fr;
            gap: 1rem;
        }

        .staff-card {
            margin-bottom: 0;
        }
    }

    @@media (max-width: 576px) {
        .staff-content {
            padding: 0 0.5rem 1rem;
        }

        .staff-card-header {
            padding: 1rem 1rem 0.5rem;
        }

        .staff-card-body {
            padding: 0 1rem 0.5rem;
        }

        .staff-card-footer {
            padding: 0.5rem 1rem 1rem;
        }

        .avatar-circle {
            width: 56px;
            height: 56px;
            font-size: 1.25rem;
        }
    }
</style>

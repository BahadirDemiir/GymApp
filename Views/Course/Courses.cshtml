@model IEnumerable<GymAppFresh.Models.Course>
@using System.Web

@section Styles {
    <link rel="stylesheet" href="~/css/shared-components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/courses.css" asp-append-version="true" />
}

<!-- Slim Header Section -->
<section class="page-header py-4">
    <div class="container">
        <div class="row justify-content-center text-center">
            <div class="col-lg-8">
                <h1 class="display-5 fw-bold text-dark mb-2">Kurslarımız</h1>
                <p class="lead text-muted mb-0">Uzman eğitmenlerimizle fitness hedeflerinize ulaşın</p>
            </div>
        </div>
    </div>
</section>

<!-- Search and Filters Section -->
@{
    ViewData["SearchPlaceholder"] = "Kurs, koç, seviye ara...";
    ViewData["SortOptions"] = new Dictionary<string, string> {
        { "popular", "En Popüler" },
        { "rating", "Puana Göre" },
        { "duration", "Süreye Göre" },
        { "startDate", "Başlangıç Tarihine Göre" }
    };
}
@await Html.PartialAsync("_SearchFilters")

<!-- Courses Grid Section -->
<section class="pb-5">
    <div class="container">
        <!-- Loading Skeleton (initially hidden) -->
        <div id="skeletonLoader" class="row g-4" style="display: none;">
            @for (int i = 0; i < 6; i++)
            {
                <div class="col-xl-4 col-md-6">
                    <div class="card item-card h-100">
                        <div class="skeleton" style="height: 200px;"></div>
                        <div class="card-body p-4">
                            <div class="skeleton mb-3" style="height: 24px; width: 60%;"></div>
                            <div class="skeleton mb-3" style="height: 20px; width: 40%;"></div>
                            <div class="skeleton mb-3" style="height: 16px; width: 80%;"></div>
                            <div class="skeleton mb-3" style="height: 16px; width: 70%;"></div>
                            <div class="d-flex gap-2 mt-auto">
                                <div class="skeleton" style="height: 38px; flex: 1;"></div>
                                <div class="skeleton" style="height: 38px; flex: 1;"></div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Courses Grid -->
        <div id="coursesGrid" class="row g-4">
            @foreach (var course in Model)
            {
                <div class="col-xl-4 col-md-6 course-item item" 
                     data-category="@course.Category.Name" 
                     data-level="@course.Level" 
                     data-name="@course.Name.ToLower()">
                    <div class="card item-card h-100 shadow-sm">
                        <!-- Course Image -->
                        <div class="position-relative overflow-hidden">
                            <img src="@course.Image" 
                                 class="item-image w-100" 
                                 style="height: 200px;" 
                                 alt="@course.Name"
                                 loading="lazy">
                            <div class="position-absolute top-0 start-0 m-3">
                                <span class="category-badge">@course.Category.Name</span>
                            </div>
                            <div class="position-absolute top-0 end-0 m-3">
                                <span class="level-badge">@course.Level</span>
                            </div>
                            <div class="position-absolute bottom-0 end-0 m-3">
                                <span class="price-tag">₺@course.Price.ToString("0")</span>
                            </div>
                        </div>
                        
                        <!-- Card Body -->
                        <div class="card-body d-flex flex-column p-4">
                            <!-- Course Name -->
                            <h5 class="card-title fw-bold text-dark mb-3">@course.Name</h5>    
                            
                            <!-- Action Buttons -->
                            <div class="mt-auto d-flex gap-2">
                                <button type="button" class="btn btn-primary" onclick="window.location.href='/course/CourseDetail/@course.Id'">Detayları Göster/Kayıt Ol</button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
        
        <!-- Empty State (initially hidden) -->
        <div id="emptyState" class="empty-state" style="display: none;">
            <i class="bi bi-search"></i>
            <h4 class="mb-3">Sonuç Bulunamadı</h4>
            <p class="mb-4">Arama kriterlerinize uygun kurs bulunamadı. Filtreleri temizleyip tekrar deneyin.</p>
            <button class="btn btn-primary" onclick="clearFilters()">
                <i class="bi bi-arrow-clockwise me-2"></i>Filtreleri Temizle
            </button>
        </div>
    </div>
</section>

<!-- Course Details Modal -->
<div class="modal fade" id="courseDetailsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Kurs Detayları</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label fw-bold text-primary">Kurs Adı:</label>
                    <p class="mb-0" id="modalCourseName"></p>
                </div>
                
                <div class="mb-3">
                    <label class="form-label fw-bold text-primary">Kurs Açıklaması:</label>
                    <p class="mb-0" id="modalCourseDescription"></p>
                </div>
                
                <div class="row mb-3">
                    <div class="col-6">
                        <label class="form-label fw-bold text-primary">Başlangıç Tarihi:</label>
                        <p class="mb-0" id="modalCourseStartDate"></p>
                    </div>
                    <div class="col-6">
                        <label class="form-label fw-bold text-primary">Süre:</label>
                        <p class="mb-0" id="modalCourseDuration"></p>
                    </div>
                </div>
                
                <div class="row mb-3">
                    <div class="col-6">
                        <label class="form-label fw-bold text-primary">Fiyat:</label>
                        <p class="mb-0" id="modalCoursePrice"></p>
                    </div>
                </div>
                
                <div class="row mb-3">
                    <div class="col-6">
                        <label class="form-label fw-bold text-primary">Mevcut Öğrenci:</label>
                        <p class="mb-0" id="modalCourseCurrentStudents"></p>
                    </div>
                    <div class="col-6">
                        <label class="form-label fw-bold text-primary">Maksimum Öğrenci:</label>
                        <p class="mb-0" id="modalCourseMaxStudents"></p>
                    </div>
                </div>
                
                <div class="row mb-3">
                    <div class="col-6">
                        <label class="form-label fw-bold text-primary">Puan:</label>
                        <p class="mb-0" id="modalCourseRating"></p>
                    </div>
                    <div class="col-6">
                        <label class="form-label fw-bold text-primary">Değerlendirme Sayısı:</label>
                        <p class="mb-0" id="modalCourseReviewCount"></p>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Kapat</button>
            </div>
        </div>
    </div>
</div>
